@model IEnumerable<WebAppBookingBoat.ViewModels.VeViewModel>

@{
    ViewData["Title"] = "Quản lý Vé Tàu";
}

<style>
    /* 1. Định dạng bảng và cột */
    #dataTable {
        table-layout: fixed;
        width: 100% !important;
        border-collapse: separate;
        border-spacing: 0;
    }

    .col-id {
        width: 70px;
    }

    .col-info {
        width: auto;
    }

    .col-seat {
        width: 140px;
    }

    .col-price {
        width: 120px;
    }

    .col-status {
        width: 140px;
    }

    .col-action {
        width: 130px;
    }

    /* 2. Hiển thị text */
    .text-main {
        display: block;
        font-weight: 700;
        color: #2c3e50;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.95rem;
    }

    .sub-text {
        display: block;
        font-size: 0.75rem;
        color: #858796;
        margin-top: 2px;
    }

    /* 3. Button Modern Style */
    .btn-modern {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s ease;
        margin: 0 2px;
        text-decoration: none !important;
        border: none;
        cursor: pointer;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-view {
        background-color: #e1f5fe;
        color: #039be5;
    }

    .btn-edit {
        background-color: #fff8e1;
        color: #f57f17;
    }

    .btn-delete {
        background-color: #ffebee;
        color: #c62828;
    }

    .btn-view:hover {
        background-color: #039be5;
        color: #fff;
    }

    .btn-edit:hover {
        background-color: #f57f17;
        color: #fff;
    }

    .btn-delete:hover {
        background-color: #c62828;
        color: #fff;
    }

    /* 4. Badge Status */
    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        display: inline-block;
        width: 100%;
        text-align: center;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-ticket-alt text-primary mr-2"></i>Quản lý Vé Tàu
        </h1>
    </div>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
            <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
            <span class="text font-weight-bold">Thêm vé mới</span>
        </a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header py-3 bg-white border-bottom">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                <i class="fas fa-list mr-1"></i> Danh sách vé đã phát hành
            </h6>
        </div>

        <div class="card-body p-0">
            <div class="px-3 pt-3">
                <div class="card shadow-sm border-0" style="background-color: #f8f9fc;">
                    <div class="card-body py-2">
                        <div class="d-flex align-items-center flex-wrap">
                            <div class="input-group input-group-sm shadow-sm mr-3" style="width: 250px;">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-info text-white border-0"><i class="fas fa-route"></i></span>
                                </div>
                                <select id="routeFilter" class="form-control border-0 font-weight-bold text-info">
                                    <option value="">Tất cả tuyến đi</option>
                                    @foreach (var route in Model.Select(m => m.ThongTinChuyen).Distinct())
                                    {
                                        <option value="@route">@route</option>
                                    }
                                </select>
                            </div>

                            <div class="input-group input-group-sm shadow-sm" style="width: 220px;">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-primary text-white border-0"><i class="fas fa-filter"></i></span>
                                </div>
                                <select id="statusFilter" class="form-control border-0 font-weight-bold text-primary">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="Hợp lệ">Hợp lệ</option>
                                    <option value="Đã sử dụng">Đã sử dụng</option>
                                    <option value="Đã hủy">Đã hủy</option>
                                </select>
                            </div>

                            <button id="btnResetFilter" class="btn btn-sm btn-outline-secondary border-0 rounded-circle shadow-sm bg-white ml-2" title="Làm mới">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive mt-2 px-3 pb-3">
                <table class="table table-hover align-middle mb-0" id="dataTable">
                    <thead class="bg-light text-muted small font-weight-bold">
                        <tr>
                            <th class="text-center col-id border-0">ID</th>
                            <th class="col-info border-0">Khách hàng & Chuyến</th>
                            <th class="col-seat border-0">Chỗ ngồi</th>
                            <th class="text-center col-price border-0">Giá vé</th>
                            <th class="text-center col-status border-0">Trạng thái</th>
                            <th class="text-center col-action border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.MaVe">
                                <td class="text-center font-weight-bold text-gray-500 small">#@item.MaVe</td>
                                <td>
                                    <span class="text-main">@item.TenKhachHang</span>
                                    <small class="sub-text text-truncate">
                                        <i class="fas fa-ship mr-1"></i>@item.TenTau | <span>@item.ThongTinChuyen</span>
                                    </small>
                                </td>
                                <td>
                                    <div class="font-weight-bold text-dark small">@item.TenGhe</div>
                                    <span class="badge badge-light border small" style="font-size: 0.65rem;">@item.LoaiGhe</span>
                                </td>
                                <td class="text-center font-weight-bold text-primary">
                                    @item.GiaVe.ToString("N0")đ
                                </td>
                                <td class="text-center">
                                    @{
                                        var sClass = item.TrangThai switch
                                        {
                                            "Hợp lệ" => "badge-success",
                                            "Đã sử dụng" => "badge-info",
                                            "Đã hủy" => "badge-danger",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge badge-status shadow-sm @sClass">@item.TrangThai</span>
                                </td>
                                <td class="text-center align-middle">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Details" asp-route-id="@item.MaVe" class="btn-modern btn-view" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.MaVe" class="btn-modern btn-edit" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <button type="button" class="btn-modern btn-delete" title="Xóa"
                                                onclick="deleteVeAjax(@item.MaVe, '@item.TenKhachHang')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/dataTables.bootstrap4.min.js"></script>

    <script>
        var table;
        $(document).ready(function() {
            table = $('#dataTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
                    "searchPlaceholder": "Tìm kiếm nhanh...",
                    "search": ""
                },
                "pageLength": 10,
                "order": [[0, "desc"]],
                "dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            // Lọc theo Tuyến đi
            $('#routeFilter').on('change', function() {
                table.column(1).search($(this).val()).draw();
            });

            // Lọc theo Trạng thái
            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(4).search(val ? '^' + val + '$' : '', true, false).draw();
            });

            // Nút Reset
            $('#btnResetFilter').on('click', function() {
                $('#statusFilter').val('');
                $('#routeFilter').val('');
                table.columns().search('').draw();
            });
        });

        // HÀM AJAX XÓA TOÀN VẸN
        function deleteVeAjax(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa vé?',
                text: "Bạn muốn xóa vé #" + id + " của khách " + name + "? Hệ thống sẽ hoàn trả 1 ghế trống cho lịch trình này.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e74a3b',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Ves")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    title: 'Đã xóa!',
                                    text: res.message,
                                    icon: 'success',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                                // Xóa dòng trong DataTable mà không reload trang
                                table.row($('#row-' + id)).remove().draw(false);
                            } else {
                                Swal.fire('Lỗi!', res.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Lỗi!', 'Không thể kết nối đến máy chủ.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
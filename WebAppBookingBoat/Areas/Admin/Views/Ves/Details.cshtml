@model WebAppBookingBoat.ViewModels.VeViewModel

@{
    ViewData["Title"] = "Chi tiết vé";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-ticket-alt text-primary mr-2"></i>Chi tiết Vé hành khách
        </h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header py-3 bg-white border-bottom">
                    <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                        <i class="fas fa-info-circle mr-1"></i> Thông tin vé #@Model.MaVe
                    </h6>
                </div>

                <div class="card-body px-lg-5 py-4">
                    <div class="row">
                        @* Cột 1: Thông tin hành trình *@
                        <div class="col-md-6 border-right">
                            <h6 class="font-weight-bold text-dark mb-3"><i class="fas fa-ship mr-2 text-primary"></i>Hành trình & Phương tiện</h6>
                            
                            <div class="mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase d-block">Tên tàu</label>
                                <div class="h6 font-weight-bold text-gray-800">@Model.TenTau</div>
                            </div>

                            <div class="mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase d-block">Chuyến đi</label>
                                <div class="p-2 bg-light border-left-primary rounded shadow-sm">
                                    <span class="font-weight-bold">@Model.ThongTinChuyen</span>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase d-block">Vị trí ghế</label>
                                <div class="h6"><span class="badge badge-info px-3">@Model.TenGhe (@Model.LoaiGhe)</span></div>
                            </div>
                        </div>

                        @* Cột 2: Thông tin thanh toán *@
                        <div class="col-md-6 pl-md-4">
                            <h6 class="font-weight-bold text-dark mb-3"><i class="fas fa-user-check mr-2 text-primary"></i>Hành khách & Thanh toán</h6>
                            
                            <div class="mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase d-block">Hành khách</label>
                                <div class="h6 font-weight-bold text-primary">@Model.TenKhachHang</div>
                            </div>

                            <div class="mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase d-block">Mã hóa đơn</label>
                                <div class="h6 text-gray-600">HĐ#@Model.MaHoaDon</div>
                            </div>

                            <div class="mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase d-block">Giá vé niêm yết</label>
                                <div class="h5 font-weight-bold text-success">@String.Format("{0:N0}", Model.GiaVe) VNĐ</div>
                            </div>

                            <div class="mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase d-block">Trạng thái</label>
                                <span class="badge @(Model.TrangThai == "Hợp lệ" ? "badge-success" : "badge-warning") p-2">
                                    <i class="fas fa-check-circle mr-1"></i>@Model.TrangThai
                                </span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
                            <span class="icon text-white-50"><i class="fas fa-arrow-left"></i></span>
                            <span class="text font-weight-bold">Quay lại</span>
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.MaVe" class="btn btn-warning btn-icon-split shadow-sm">
                            <span class="icon text-white-50"><i class="fas fa-edit"></i></span>
                            <span class="text font-weight-bold">Chỉnh sửa vé</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary { border-left: 4px solid #4e73df !important; }
</style>
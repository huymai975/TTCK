@model IEnumerable<WebAppBookingBoat.Models.HoaDon>

@{
    ViewData["Title"] = "Quản lý Hóa đơn";
}

<style>
    /* 1. KHUNG BẢNG & TỈ LỆ CỘT */
    #dataTable {
        table-layout: fixed;
        width: 100% !important;
        border-collapse: separate;
        border-spacing: 0;
    }

    .col-id {
        width: 50px;
    }

    .col-customer {
        width: auto;
    }

    .col-date {
        width: 120px;
    }

    .col-amount {
        width: 130px;
    }

    .col-method {
        width: 110px;
    }

    .col-status {
        width: 130px;
    }

    .col-action {
        width: 130px;
    }

    /* 2. STYLE NỘI DUNG */
    .text-main-bold {
        display: block;
        font-weight: 700;
        color: #2c3e50;
        line-height: 1.3;
        font-size: 0.95rem;
    }

    /* 3. NÚT THAO TÁC (SOFT UI) */
    .btn-modern {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s ease;
        margin: 0 2px;
        text-decoration: none !important;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-view {
        background-color: #e1f5fe;
        color: #039be5;
    }

    .btn-edit {
        background-color: #fff8e1;
        color: #f57f17;
    }

    .btn-delete {
        background-color: #ffebee;
        color: #c62828;
    }

    .btn-view:hover {
        background-color: #039be5;
        color: #fff;
    }

    .btn-edit:hover {
        background-color: #f57f17;
        color: #fff;
    }

    .btn-delete:hover {
        background-color: #c62828;
        color: #fff;
    }

    .badge-status {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* Tiền tệ */
    .amount-total {
        color: #1cc88a;
        font-weight: 800;
        font-size: 1rem;
    }

    .amount-discount {
        color: #e74a3b;
        font-size: 0.8rem;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fa-solid fa-file-invoice-dollar text-primary mr-2"></i>Quản lý Hóa đơn
        </h1>
    </div>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
            <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
            <span class="text font-weight-bold">Lập hóa đơn mới</span>
        </a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header py-3 bg-white border-bottom">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                <i class="fas fa-list mr-1"></i> Danh sách chứng từ thanh toán
            </h6>
        </div>

        <div class="card-body p-0">
            <div class="px-3 pt-3">
                <div class="card shadow-sm border-0" style="background-color: #f8f9fc;">
                    <div class="card-body py-2">
                        <div class="d-flex align-items-center flex-wrap">
                            <div class="input-group input-group-sm shadow-sm mr-2" style="width: 250px;">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-info text-white border-0"><i class="fas fa-filter"></i></span>
                                </div>
                                <select id="statusFilter" class="form-control border-0 font-weight-bold text-info">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="Đã thanh toán">Đã thanh toán</option>
                                    <option value="Chưa thanh toán">Chưa thanh toán</option>
                                    <option value="Đã hủy">Đã hủy</option>
                                </select>
                            </div>
                            <button id="btnResetFilter" class="btn btn-sm btn-outline-secondary border-0 rounded-circle shadow-sm bg-white" title="Làm mới">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive mt-2">
                <table class="table table-hover align-middle mb-0" id="dataTable">
                    <thead class="bg-light text-muted small font-weight-bold">
                        <tr>
                            <th class="text-center col-id border-0">ID</th>
                            <th class="col-customer border-0">Khách hàng / Nhân viên</th>
                            <th class="col-date border-0">Ngày lập</th>
                            <th class="text-right col-amount border-0">Tổng tiền</th>
                            <th class="text-center col-method border-0">HTTT</th>
                            <th class="text-center col-status border-0">Trạng thái</th>
                            <th class="text-center col-action border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center font-weight-bold text-gray-500 small align-middle">
                                    #@item.MaHoaDon
                                </td>
                                <td class="align-middle">
                                    <span class="text-main-bold">@item.KhachHang?.HoTen</span>
                                    <small class="text-muted d-block">
                                        <i class="fa-solid fa-user-check mr-1"></i>NV: @(item.NhanVien?.HoTen ?? "Online")
                                    </small>
                                </td>
                                <td class="align-middle">
                                    <div class="small font-weight-bold text-dark">
                                        <i class="fa-regular fa-calendar-check mr-1 text-primary"></i>@item.NgayLap.ToString("dd/MM/yyyy")
                                    </div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@item.NgayLap.ToString("HH:mm")</div>
                                </td>
                                <td class="text-right align-middle">
                                    <div class="amount-total">@item.TongTien.ToString("N0")đ</div>
                                    @if (item.SoTienGiam > 0)
                                    {
                                        <div class="amount-discount">-@item.SoTienGiam.ToString("N0")đ</div>
                                    }
                                    <small class="text-muted" style="font-size: 0.7rem;">SL: @item.SoLuongVe vé</small>
                                </td>
                                <td class="text-center align-middle">
                                    <span class="badge badge-light border shadow-sm small">
                                        <i class="fa-solid fa-wallet mr-1 text-secondary"></i>@item.PhuongThucTT
                                    </span>
                                </td>
                                <td class="text-center align-middle">
                                    @{
                                        var (sClass, sIcon) = item.TrangThai switch
                                        {
                                            "Đã thanh toán" => ("badge-success", "fa-solid fa-circle-check"),
                                            "Chưa thanh toán" => ("badge-warning", "fa-solid fa-hourglass-half"),
                                            "Đã hủy" => ("badge-danger", "fa-solid fa-ban"),
                                            _ => ("badge-secondary", "fa-solid fa-file-invoice")
                                        };
                                    }
                                    <span class="badge badge-status shadow-sm @sClass d-inline-flex align-items-center">
                                        <i class="@sIcon mr-1"></i> @item.TrangThai
                                    </span>
                                </td>
                                <td class="text-center align-middle">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Details" asp-route-id="@item.MaHoaDon" class="btn-modern btn-view" title="Xem chi tiết">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaHoaDon" class="btn-modern btn-edit" title="Sửa hóa đơn">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <button type="button" class="btn-modern btn-delete" onclick="deleteHoaDonAjax(@item.MaHoaDon)" title="Xóa">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var table;
        $(document).ready(function() {
            table = $('#dataTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
                    "search": "Tìm hóa đơn:",
                    "searchPlaceholder": "Mã HD, tên khách..."
                },
                "pageLength": 10,
                "order": [[0, "desc"]],
                "dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(5).search(val ? '^' + val + '$' : '', true, false).draw();
            });

            $('#btnResetFilter').on('click', function() {
                $('#statusFilter').val('');
                table.search('').column(5).search('').draw();
            });
        });

        function deleteHoaDonAjax(id) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: `Dữ liệu hóa đơn #${id} sẽ bị xóa vĩnh viễn!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e74a3b',
                cancelButtonColor: '#858796',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("Delete", "HoaDons")', {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(response) {
                        if (response.success) {
                            Swal.fire('Đã xóa!', response.message, 'success').then(() => location.reload());
                        } else {
                            Swal.fire('Lỗi!', response.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
@model WebAppBookingBoat.Models.Ghe

@{
    ViewData["Title"] = "Điều chỉnh thông tin Ghế";
}

<style>
    .border-left-primary {
        border-left: 4px solid #4e73df !important;
    }

    .border-left-info {
        border-left: 4px solid #36b9cc !important;
    }

    .border-left-warning {
        border-left: 4px solid #f6c23e !important;
    }

    .form-control-user {
        border-radius: 8px;
        height: calc(1.5em + .75rem + 10px);
    }

    .form-control:focus {
        border-color: #f6c23e;
        box-shadow: 0 0 0 0.2rem rgba(246, 194, 62, 0.15);
    }
</style>

<div class="container-fluid">
    @* Tiêu đề trang đồng bộ *@
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-edit text-warning mr-2"></i>Điều chỉnh thông tin Ghế
        </h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <form asp-action="Edit" method="post" class="card shadow-lg mb-4 border-left-warning">
                @* Card Header hiển thị mã định danh *@
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary text-uppercase">
                        Mã ghế: #@Model.MaGhe
                    </h6>
                    <span class="badge badge-warning text-white p-2 shadow-sm">
                        <i class="fas fa-couch mr-1"></i> Cập nhật vị trí & hạng ghế
                    </span>
                </div>

                <div class="card-body px-lg-5 py-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small shadow-sm" role="alert"></div>

                    @* Hidden field *@
                    <input type="hidden" asp-for="MaGhe" />

                    <div class="row">
                        <div class="col-md-12">
                            <h6 class="font-weight-bold text-dark mb-3">
                                <i class="fas fa-ship mr-2 text-warning"></i>Thông tin vận hành
                            </h6>

                            <div class="form-group mb-4">
                                <label asp-for="MaTau" class="small font-weight-bold text-muted text-uppercase">Tàu sở hữu</label>
                                <select asp-for="MaTau" class="form-control form-control-user border-left-primary shadow-sm"
                                        asp-items="ViewBag.MaTau">
                                </select>
                                <span asp-validation-for="MaTau" class="text-danger small mt-1"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label asp-for="TenGhe" class="small font-weight-bold text-muted text-uppercase">Tên / Số ghế</label>
                                        <input asp-for="TenGhe" class="form-control form-control-user border-left-info shadow-sm" />
                                        <span asp-validation-for="TenGhe" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label asp-for="LoaiGhe" class="small font-weight-bold text-muted text-uppercase">Hạng ghế</label>
                                        <select asp-for="LoaiGhe" class="form-control form-control-user border-left-warning shadow-sm">
                                            <option value="Thường">Ghế Thường</option>
                                            <option value="VIP">Ghế VIP</option>
                                        </select>
                                        <span asp-validation-for="LoaiGhe" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Footer với các nút thao tác *@
                <div class="card-footer bg-light d-flex justify-content-between py-3">
                    <a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-left"></i>
                        </span>
                        <span class="text font-weight-bold">Hủy thay đổi</span>
                    </a>

                    <button type="submit" class="btn btn-warning btn-icon-split shadow-sm font-weight-bold">
                        <span class="icon text-white-50">
                            <i class="fas fa-save"></i>
                        </span>
                        <span class="text">Lưu cập nhật</span>
                    </button>
                </div>
            </form>

            @* Cảnh báo thông tin *@
            <div class="alert alert-warning border-0 shadow-sm small">
                <i class="fas fa-exclamation-triangle mr-1"></i>
                <strong>Lưu ý:</strong> Việc thay đổi <strong>Tên ghế</strong> hoặc <strong>Hạng ghế</strong> có thể ảnh hưởng đến các vé đang trong quá trình thanh toán. Hãy đảm bảo thông báo cho bộ phận bán vé nếu có thay đổi lớn.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
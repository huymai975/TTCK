	<style>
		/* 1. Cố định vị trí và hiệu ứng ẩn/hiện mượt mà */
		.topbar .dropdown-menu {
			display: block !important; /* Luôn render để chạy transition */
			visibility: hidden;
			opacity: 0;
			transform: translateY(10px);
			transition: opacity 0.4s ease, visibility 0.4s ease, transform 0.4s ease;
			/* Chống đụng viền và bo góc */
			border-radius: 12px !important;
			border: none !important;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
			overflow: hidden;
			margin-top: 0 !important;
		}

		/* 2. Cầu nối vô hình: Giúp chuột di từ Icon xuống Menu không bị mất */
		.topbar .nav-item.dropdown::after {
			content: "";
			position: absolute;
			top: 100%;
			left: 0;
			width: 100%;
			height: 20px; /* Vùng đệm */
			z-index: 1;
		}

		/* 3. Hiển thị khi Hover vào Icon hoặc Menu */
		.topbar .nav-item.dropdown:hover .dropdown-menu {
			visibility: visible;
			opacity: 1;
			transform: translateY(0);
		}

		/* 4. Đồng bộ kích thước và khoảng cách cho phần Chuông & Tin nhắn */
		.topbar .dropdown-list {
			width: 320px !important;
			min-width: 320px !important;
		}

		.topbar .dropdown-item {
			display: flex !important;
			align-items: center;
			padding: 15px 20px !important;
			white-space: normal;
			border-bottom: 1px solid #f8f9fc;
			transition: background 0.2s ease;
		}

			.topbar .dropdown-item:last-child {
				border-bottom: none;
			}

			/* Chỉnh chữ không bị dính viền */
			.topbar .dropdown-item > div:last-child {
				flex: 1;
				padding-left: 5px;
			}

		/* 5. Hiệu ứng Icon khi Hover */
		.topbar .nav-link i {
			transition: transform 0.3s ease, color 0.3s ease;
		}

		.topbar .nav-item.dropdown:hover .nav-link i {
			color: #4e73df;
			transform: scale(1.2);
		}
	</style>



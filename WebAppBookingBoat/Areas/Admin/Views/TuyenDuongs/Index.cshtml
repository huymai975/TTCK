@model IEnumerable<WebAppBookingBoat.Models.TuyenDuong>

@{
    ViewData["Title"] = "Quản lý Tuyến Đường";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    /* GIỮ NGUYÊN STYLE CỦA HUY - ĐÃ RẤT ĐẸP VÀ ĐỒNG BỘ */
    #dataTableRoutes {
        table-layout: fixed;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .col-id {
        width: 30px;
    }

    .col-route {
        width: auto;
    }

    .col-img {
        width: 120px;
    }

    .col-distance {
        width: 140px;
    }

    .col-time {
        width: 130px;
    }

    .col-action {
        width: 155px;
    }

    .btn-modern {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s ease;
        border: none;
        margin: 0 2px;
        text-decoration: none !important;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            text-decoration: none !important;
        }

    .btn-view {
        background-color: #e1f5fe;
        color: #039be5;
    }

    .btn-edit {
        background-color: #fff8e1;
        color: #f57f17;
    }

    .btn-delete {
        background-color: #ffebee;
        color: #c62828;
    }

    .btn-view:hover {
        background-color: #039be5;
        color: #fff;
    }

    .btn-edit:hover {
        background-color: #f57f17;
        color: #fff;
    }

    .btn-delete:hover {
        background-color: #c62828;
        color: #fff;
    }

    .dataTables_filter input {
        border-radius: 8px !important;
        border: 1px solid #d1d3e2 !important;
        padding: 0.4rem 0.75rem !important;
        width: 250px !important;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-map-marked-alt text-primary mr-2"></i>Quản lý Tuyến Đường
        </h1>
    </div>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
            <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
            <span class="text font-weight-bold">Thêm mới tuyến đường</span>
        </a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header py-3 bg-white border-bottom d-flex align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                <i class="fas fa-route mr-1"></i> Danh sách hành trình
            </h6>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive px-3 pb-3">
                <table class="table table-hover align-middle mb-0" id="dataTableRoutes">
                    <thead class="bg-light text-muted small font-weight-bold">
                        <tr>
                            <th class="text-center col-id border-0">ID</th>
                            <th class="col-route border-0">Thông tin tuyến</th>
                            <th class="text-center col-img border-0">Hình ảnh</th>
                            <th class="text-center col-distance border-0">Khoảng cách</th>
                            <th class="text-center col-time border-0">Dự kiến</th>
                            <th class="text-center col-action border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.MaTuyen">
                                <td class="text-center align-middle font-weight-bold text-gray-500">#@item.MaTuyen</td>
                                <td class="align-middle">
                                    <span class="font-weight-bold text-dark">@item.TenTuyen</span><br />
                                    <small class="text-muted small">@item.DiemDi <i class="fas fa-arrow-right mx-1 fa-xs"></i> @item.DiemDen</small>
                                </td>
                                <td class="text-center align-middle">
                                    <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/tuyen-duong/default-route.jpg" : "/images/tuyen-duong/" + item.HinhAnh)"
                                         width="95" class="rounded shadow-sm border" style="height: 52px; object-fit: cover;" />
                                </td>
                                <td class="text-center align-middle">
                                    <span class="badge badge-light border px-2 py-1 text-dark">@item.KhoangCach km</span>
                                </td>
                                <td class="text-center align-middle">
                                    <span class="text-primary font-weight-bold"><i class="far fa-clock mr-1"></i>@item.ThoiGianDuKien.ToString(@"hh\:mm")</span>
                                </td>
                                <td class="text-center align-middle">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Details" asp-route-id="@item.MaTuyen" class="btn-modern btn-view"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.MaTuyen" class="btn-modern btn-edit"><i class="fas fa-edit"></i></a>
                                        <button type="button" class="btn-modern btn-delete"
                                                onclick="deleteKhachHangAjax(@item.MaTuyen, '@item.TenTuyen')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken() @* Quan trọng để AJAX POST hoạt động *@

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <script>
        var table;
        $(document).ready(function() {
            table = $('#dataTableRoutes').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
                    "search": "Tìm kiếm:",
                    "searchPlaceholder": "Tìm tên tuyến, điểm đi/đến...",
                    "paginate": {
                    // Thêm icon vào nút phân trang
                    "previous": "<i class='fas fa-angle-left'></i>",
                    "next": "<i class='fas fa-angle-right'></i>",
                    "first": "<i class='fas fa-angle-double-left'></i>",
                    "last": "<i class='fas fa-angle-double-right'></i>"
                }
                },
                "pageLength": 10,
                "order": [[0, "desc"]],
                "columnDefs": [ { "orderable": false, "targets": [2, 5] } ],
                "dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
                "drawCallback": function() {
                    $('.dataTables_paginate > .pagination').addClass('pagination-sm');
                }
            });
        });

                function deleteKhachHangAjax(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: `Bạn có chắc muốn xóa tuyến "${name}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e74a3b',
                cancelButtonColor: '#858796',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        // Đảm bảo tên Action và Controller chính xác
                        url: '@Url.Action("DeleteAjax", "KhachHangs")',
                        type: 'POST',
                        data: {
                            id: id,
                            // Lấy token để vượt qua kiểm tra [ValidateAntiForgeryToken]
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    title: 'Thành công!',
                                    text: response.message,
                                    icon: 'success',
                                    timer: 1500,
                                    showConfirmButton: false
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                // Hiện thông báo lỗi nếu vi phạm ràng buộc (ví dụ: đã có hóa đơn)
                                Swal.fire('Không thể xóa!', response.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Lỗi!', 'Có lỗi xảy ra trong quá trình xử lý.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
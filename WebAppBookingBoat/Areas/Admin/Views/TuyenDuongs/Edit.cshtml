@model WebAppBookingBoat.ViewModels.TuyenDuongViewModel

@{
    ViewData["Title"] = "Cập nhật tuyến đường";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-edit text-warning mr-2"></i>Cập nhật tuyến đường
        </h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            <form asp-action="Edit" enctype="multipart/form-data" class="card shadow-lg mb-4 border-left-warning">
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary text-uppercase">Mã tuyến đường: #@Model.MaTuyen</h6>
                    <span class="badge badge-warning text-white p-2">
                        <i class="fas fa-tools mr-1"></i> Chế độ chỉnh sửa
                    </span>
                </div>

                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 d-none"></div>

                    @* Thông tin ẩn cần thiết *@
                    <input type="hidden" asp-for="MaTuyen" />
                    <input type="hidden" asp-for="HinhAnhCu" />

                    <div class="row">
                        @* Cột trái: Quản lý hình ảnh *@
                        <div class="col-md-4 text-center border-right">
                            <label class="font-weight-bold text-dark d-block mb-3">Quản lý hình ảnh</label>

                            <div class="mb-3 p-2 border rounded bg-light">
                                <small class="text-muted d-block mb-1 font-italic">Ảnh đang sử dụng:</small>
                                @if (!string.IsNullOrEmpty(Model.HinhAnhCu))
                                {
                                    <img id="previewImg" src="~/images/tuyen-duong/@Model.HinhAnhCu" class="img-fluid rounded shadow-sm" style="max-height: 200px; width: 100%; object-fit: cover;" alt="Ảnh cũ" />
                                }
                                else
                                {
                                    <img id="previewImg" src="~/images/tuyen-duong/default-route.jpg" class="img-fluid rounded shadow-sm" style="max-height: 200px; width: 100%; object-fit: cover;" alt="Default" />
                                }
                            </div>

                            <div class="custom-file text-left mt-3 shadow-sm">
                                <input asp-for="ImageFile" id="imageInputEdit" type="file" class="custom-file-input" accept="image/*" />
                                <label class="custom-file-label text-truncate" for="imageInputEdit">Thay đổi ảnh...</label>
                            </div>
                            <small class="text-muted d-block mt-2 font-italic small">
                                <i class="fas fa-info-circle mr-1"></i>Để trống nếu giữ nguyên ảnh cũ.
                            </small>
                        </div>

                        @* Cột phải: Thông tin tuyến đường *@
                        <div class="col-md-8 pl-md-4">
                            <div class="row">
                                <div class="col-12 form-group mb-4">
                                    <label asp-for="TenTuyen" class="font-weight-bold text-dark">Tên tuyến đường</label>
                                    <div class="input-group shadow-sm">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-warning text-white"><i class="fas fa-map-marked-alt"></i></span>
                                        </div>
                                        <input asp-for="TenTuyen" class="form-control border-left-0" placeholder="VD: Rạch Giá - Phú Quốc" />
                                    </div>
                                    <span asp-validation-for="TenTuyen" class="text-danger small font-italic"></span>
                                </div>

                                <div class="col-md-6 form-group mb-4">
                                    <label asp-for="DiemDi" class="font-weight-bold text-dark small text-uppercase">Điểm xuất phát</label>
                                    <input asp-for="DiemDi" class="form-control shadow-sm border-left-danger" />
                                    <span asp-validation-for="DiemDi" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 form-group mb-4">
                                    <label asp-for="DiemDen" class="font-weight-bold text-dark small text-uppercase">Điểm đến</label>
                                    <input asp-for="DiemDen" class="form-control shadow-sm border-left-success" />
                                    <span asp-validation-for="DiemDen" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 form-group mb-4">
                                    <label asp-for="KhoangCach" class="font-weight-bold text-dark">Khoảng cách (km)</label>
                                    <div class="input-group shadow-sm">
                                        <input asp-for="KhoangCach" type="number" step="0.1" class="form-control" />
                                        <div class="input-group-append">
                                            <span class="input-group-text bg-light text-dark font-weight-bold">km</span>
                                        </div>
                                    </div>
                                    <span asp-validation-for="KhoangCach" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 form-group mb-4">
                                    <label asp-for="ThoiGianDuKien" class="font-weight-bold text-dark">Thời gian dự kiến</label>
                                    <div class="input-group shadow-sm">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-light"><i class="far fa-clock"></i></span>
                                        </div>
                                        <input asp-for="ThoiGianDuKien" type="time" class="form-control" />
                                    </div>
                                    <span asp-validation-for="ThoiGianDuKien" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light d-flex justify-content-between py-3">
                    <a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-left"></i>
                        </span>
                        <span class="text">Hủy thay đổi</span>
                    </a>

                    <button type="submit" class="btn btn-warning btn-icon-split shadow-sm font-weight-bold">
                        <span class="icon text-white-50">
                            <i class="fas fa-check-circle"></i>
                        </span>
                        <span class="text">Cập nhật dữ liệu</span>
                    </button>
                </div>
            </form>

            <p class="mb-5 small text-muted text-center">
                <i class="fas fa-shield-alt mr-1"></i> Hệ thống tự động ghi lại lịch sử chỉnh sửa bởi Admin.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Logic Preview ảnh và hiển thị tên file đồng bộ với trang Tàu
        $('#imageInputEdit').on('change', function(e) {
            // Hiện tên file
            let fileName = $(this).val().split('\\').pop();
            $(this).next('.custom-file-label').addClass("selected").html(fileName);

            // Hiện ảnh xem trước
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    $('#previewImg').attr('src', e.target.result);
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
}
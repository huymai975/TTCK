@model WebAppBookingBoat.Models.Tau

@{
    ViewData["Title"] = "Xóa tàu";
}

<div class="container-fluid">
    <h1 class="h3 mb-0 text-gray-800">Xác nhận xóa tàu</h1>
    <br />
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        Bạn có chắc chắn muốn xóa con tàu này không? Hành động này không thể hoàn tác.
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="shadow-sm p-4 border rounded bg-white">
            @* Hiển thị thông tin tóm tắt để người dùng xác nhận *@
            <div class="text-center mb-4">
                <img src="~/images/tau/@Model.HinhAnh" width="200" class="img-thumbnail rounded mb-3" alt="Ảnh tàu" />
                <h3 class="fw-bold">@Model.TenTau</h3>
            </div>

            <hr />

            <dl class="row px-3">
                <dt class="col-sm-6">Số ghế thường:</dt>
                <dd class="col-sm-6 text-end">@Model.SoGheThuong</dd>

                <dt class="col-sm-6">Số ghế VIP:</dt>
                <dd class="col-sm-6 text-end">@Model.SoGheVIP</dd>

                <dt class="col-sm-6 fw-bold text-primary">Tổng số ghế:</dt>
                <dd class="col-sm-6 text-end fw-bold text-primary">@Model.TongSoGhe</dd>

                <dt class="col-sm-6">Trạng thái:</dt>
                <dd class="col-sm-6 text-end">
                    @* @(Model.TrangThai ? "Đang hoạt động" : "Tạm ngưng") *@

                    @if (Model.TrangThai)
                    {
                        <span class="badge badge-success px-2 py-1">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="badge badge-danger px-2 py-1">Tạm ngưng</span>
                    }
                </dd>
            </dl>

            <hr />

            @* Form gửi yêu cầu POST để xóa *@
            <form asp-action="Delete" class="d-flex justify-content-between mt-4">
                <input type="hidden" asp-for="MaTau" />

                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Quay lại danh sách
                </a>

                <button type="submit" class="btn btn-danger px-5">
                    Xác nhận xóa
                </button>
            </form>
        </div>
    </div>
</div>
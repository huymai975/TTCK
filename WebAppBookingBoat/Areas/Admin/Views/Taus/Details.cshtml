@model WebAppBookingBoat.Models.Tau

@{
    ViewData["Title"] = "Chi tiết phương tiện";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-info-circle text-info mr-2"></i>Hồ sơ phương tiện
        </h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">
            <div class="card shadow-lg mb-4 border-left-info">
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-info text-uppercase">Mã tàu: #@Model.MaTau.ToString("D3")</h6>
                    <span class="badge badge-light border text-muted shadow-sm px-3 py-2">
                        <i class="fas fa-database mr-1"></i> Dữ liệu hệ thống
                    </span>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-5 text-center border-right">
                            <div class="p-2 border rounded bg-light mb-3 shadow-sm">
                                <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/tau/default-boat.jpg" : "/images/tau/" + Model.HinhAnh)"
                                     class="img-fluid rounded"
                                     alt="@Model.TenTau"
                                     style="width: 100%; max-height: 300px; object-fit: cover;" />
                            </div>
                            <div class="mt-3 px-3">
                                @if (Model.TrangThai)
                                {
                                    <div class="alert alert-success py-2 border-left-success shadow-sm">
                                        <i class="fas fa-check-circle mr-2"></i>Sẵn sàng vận hành
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-danger py-2 border-left-danger shadow-sm">
                                        <i class="fas fa-exclamation-triangle mr-2"></i>Tạm dừng hoạt động
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-md-7 pl-md-4">
                            <h2 class="font-weight-bold text-dark mb-4">@Model.TenTau</h2>

                            <div class="row mb-4">
                                @* Đã lược bỏ các box ghế lẻ, tập trung vào tổng sức chứa *@
                                <div class="col-12">
                                    <div class="p-4 border-left-info bg-gray-100 rounded shadow-sm d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Tổng sức chứa hành khách</div>
                                            <div class="h3 mb-0 font-weight-bold text-gray-900">@Model.TongSoGhe <small>chỗ ngồi</small></div>
                                        </div>
                                        <i class="fas fa-users fa-3x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>

                            <p class="text-muted italic small">
                                <i class="fas fa-quote-left mr-1"></i> Thông tin sức chứa này được sử dụng để giới hạn số lượng vé bán ra trên hệ thống trực tuyến.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light d-flex justify-content-between py-3">
                    <a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-left"></i>
                        </span>
                        <span class="text">Danh sách tàu</span>
                    </a>

                    <a asp-action="Edit" asp-route-id="@Model.MaTau" class="btn btn-warning btn-icon-split shadow-sm font-weight-bold">
                        <span class="icon text-white-50">
                            <i class="fas fa-edit"></i>
                        </span>
                        <span class="text">Hiệu chỉnh dữ liệu</span>
                    </a>
                </div>
            </div>

            <p class="mb-5 small text-muted text-center">
                <i class="fas fa-shield-alt mr-1"></i> Thông tin được xác thực bởi hệ thống quản lý Water Boat Booking
            </p>
        </div>
    </div>
</div>
@model WebAppBookingBoat.ViewModels.TauViewModel

@{
	ViewData["Title"] = "Cập nhật thông tin tàu";
}

<div class="container-fluid">
	<div class="d-sm-flex align-items-center justify-content-between mb-4">
		<h1 class="h3 mb-0 text-gray-800 font-weight-bold">
			<i class="fas fa-edit text-warning mr-2 font-weight-bold"></i>Cập nhật phương tiện
		</h1>
	</div>

	<div class="row justify-content-center">
		<div class="col-xl-10 col-lg-12">
			<form asp-action="Edit" enctype="multipart/form-data" class="card shadow-lg mb-4 border-left-warning">
				<div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
					<h6 class="m-0 font-weight-bold text-primary text-uppercase">Mã phương tiện: #@Model.MaTau</h6>
					<span class="badge badge-warning text-white p-2">
						<i class="fas fa-tools mr-1"></i> Chế độ chỉnh sửa
					</span>
				</div>

				<div class="card-body">
					<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 d-none"></div>

					@* Thông tin ẩn cần thiết *@
					<input type="hidden" asp-for="MaTau" />
					<input type="hidden" asp-for="HinhAnhCu" />

					<div class="row">
						<div class="col-md-4 text-center border-right">
							<label class="font-weight-bold text-dark d-block mb-3">Quản lý hình ảnh</label>

							<div class="mb-3 p-2 border rounded bg-light">
								<small class="text-muted d-block mb-1 font-italic">Ảnh đang sử dụng:</small>
								@if (!string.IsNullOrEmpty(Model.HinhAnhCu))
								{
									<img src="~/images/tau/@Model.HinhAnhCu" class="img-fluid rounded shadow-sm" style="max-height: 150px; object-fit: cover;" alt="Ảnh cũ" />
								}
								else
								{
									<img src="~/images/tau/default-boat.jpg" class="img-fluid rounded shadow-sm" style="max-height: 150px; object-fit: cover;" alt="Default" />
								}
							</div>

							<i class="fas fa-arrow-down text-warning mb-3"></i>

							<div class="mb-3">
								<small class="text-primary d-block mb-1 font-weight-bold">Ảnh mới thay thế:</small>
								<img id="imgPreviewEdit" src="#" class="img-fluid rounded shadow-sm d-none"
									 style="max-height: 150px; width: 100%; object-fit: cover; border: 2px dashed #f6c23e;" alt="Preview mới" />
							</div>

							<div class="custom-file text-left mt-2">
								<input asp-for="ImageFile" id="imageInputEdit" type="file" class="custom-file-input" accept="image/*" />
								<label class="custom-file-label text-truncate" for="imageInputEdit">Chọn ảnh mới...</label>
							</div>
						</div>

						<div class="col-md-8 pl-md-4">
							<div class="row">
								<div class="col-12 form-group mb-4">
									<label asp-for="TenTau" class="font-weight-bold text-dark">Tên tàu</label>
									<div class="input-group">
										<div class="input-group-prepend">
											<span class="input-group-text bg-warning text-white"><i class="fas fa-ship"></i></span>
										</div>
										<input asp-for="TenTau" class="form-control border-left-0" />
									</div>
									<span asp-validation-for="TenTau" class="text-danger small font-italic"></span>
								</div>

								<div class="col-md-6 form-group mb-4">
									<label asp-for="SoGheThuong" class="font-weight-bold text-dark">Số ghế Thường</label>
									<input asp-for="SoGheThuong" class="form-control shadow-sm" id="SoGheThuong" type="number" min="0" />
									<span asp-validation-for="SoGheThuong" class="text-danger small"></span>
								</div>

								<div class="col-md-6 form-group mb-4">
									<label asp-for="SoGheVIP" class="font-weight-bold text-dark">Số ghế VIP</label>
									<input asp-for="SoGheVIP" class="form-control border-warning shadow-sm" id="SoGheVIP" type="number" min="0" />
									<span asp-validation-for="SoGheVIP" class="text-danger small"></span>
								</div>

								<div class="col-12 form-group mb-4">
									<label asp-for="TongSoGhe" class="font-weight-bold text-danger text-uppercase small">Tổng sức chứa (Tự động)</label>
									<input asp-for="TongSoGhe" class="form-control bg-light font-weight-bold text-primary shadow-sm" id="TongSoGhe" readonly style="font-size: 1.25rem;" />
									<div class="form-text mt-1 text-muted small italic">
										<i class="fas fa-info-circle"></i> Giá trị này được tính toán tự động dựa trên cấu hình ghế bên trên.
									</div>
								</div>

								<div class="col-12 form-group mb-0">
									<div class="custom-control custom-switch custom-switch-lg">
										<input type="checkbox" class="custom-control-input" asp-for="TrangThai" id="statusSwitch">
										<label class="custom-control-label font-weight-bold text-success" for="statusSwitch">Sẵn sàng vận hành</label>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="card-footer bg-light d-flex justify-content-between py-3">
					<a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
						<span class="icon text-white-50">
							<i class="fas fa-arrow-left"></i>
						</span>
						<span class="text">Danh sách tàu</span>
					</a>

					<button type="submit" class="btn btn-warning btn-icon-split shadow-sm font-weight-bold">
						<span class="icon text-white-50">
							<i class="fas fa-check-circle"></i>
						</span>
						<span class="text">Cập nhật dữ liệu</span>
					</button>
				</div>
			</form>

			<p class="mb-5 small text-muted text-center">
				<i class="fas fa-info-circle mr-1"></i> Lưu ý: Mọi thay đổi sẽ ảnh hưởng trực tiếp đến lịch trình và việc đặt chỗ.
			</p>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script src="~/js/tau-logic.js"></script>
	<script>
				// Hiển thị tên file và preview ảnh ngay lập tức
		$('.custom-file-input').on('change', function(e) {
			// 1. Hiện tên file
			let fileName = $(this).val().split('\\').pop();
			$(this).next('.custom-file-label').addClass("selected").html(fileName);

			// 2. Hiện ảnh xem trước
			const file = e.target.files[0];
			if (file) {
				const reader = new FileReader();
				reader.onload = function(e) {
					$('#imgPreview').attr('src', e.target.result);
				}
				reader.readAsDataURL(file);
			}
		});
	</script>
}
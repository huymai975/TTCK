@model WebAppBookingBoat.ViewModels.TauViewModel

@{
	ViewData["Title"] = "Cập nhật thông tin tàu";
}

<div class="container-fluid">
	<div class="d-sm-flex align-items-center justify-content-between mb-4">
		<h1 class="h3 mb-0 text-gray-800 font-weight-bold">
			<i class="fas fa-edit text-warning mr-2 font-weight-bold"></i>Cập nhật phương tiện
		</h1>
	</div>

	<div class="row justify-content-center">
		<div class="col-xl-10 col-lg-12">
			<form asp-action="Edit" enctype="multipart/form-data" class="card shadow-lg mb-4 border-left-warning">
				<div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
					<h6 class="m-0 font-weight-bold text-primary text-uppercase">Mã phương tiện: #@Model.MaTau.ToString("D3")</h6>
					<span class="badge badge-warning text-white p-2">
						<i class="fas fa-tools mr-1"></i> Chế độ chỉnh sửa
					</span>
				</div>

				<div class="card-body">
					<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 d-none"></div>

					@* Thông tin ẩn cần thiết *@
					<input type="hidden" asp-for="MaTau" />
					<input type="hidden" asp-for="HinhAnhCu" />

					<div class="row">
						<div class="col-md-4 text-center border-right">
							<label class="font-weight-bold text-dark d-block mb-3">Quản lý hình ảnh</label>

							<div class="mb-3 p-2 border rounded bg-light shadow-sm">
								<small class="text-muted d-block mb-1 font-italic">Ảnh đang sử dụng:</small>
								<img id="imgPreview"
									 src="@(string.IsNullOrEmpty(Model.HinhAnhCu) ? "/images/tau/default-boat.jpg" : "/images/tau/" + Model.HinhAnhCu)"
									 class="img-fluid rounded shadow-sm"
									 style="max-height: 200px; width: 100%; object-fit: cover;"
									 alt="Ảnh phương tiện" />
							</div>

							<div class="custom-file text-left mt-2">
								<input asp-for="ImageFile" id="imageInput" type="file" class="custom-file-input" accept="image/*" />
								<label class="custom-file-label text-truncate" for="imageInput">Thay đổi ảnh mới...</label>
								<span asp-validation-for="ImageFile" class="text-danger small font-italic"></span>
							</div>
							<small class="form-text text-muted mt-2 small font-italic">
								<i class="fas fa-info-circle mr-1"></i> Chọn ảnh mới nếu muốn thay thế ảnh cũ.
							</small>
						</div>

						<div class="col-md-8 pl-md-4">
							<div class="row">
								<div class="col-12 form-group mb-4">
									<label asp-for="TenTau" class="font-weight-bold text-dark">Tên phương tiện</label>
									<div class="input-group input-group-lg">
										<div class="input-group-prepend">
											<span class="input-group-text bg-warning text-white border-0"><i class="fas fa-ship"></i></span>
										</div>
										<input asp-for="TenTau" class="form-control border-left-0" placeholder="Nhập tên tàu..." />
									</div>
									<span asp-validation-for="TenTau" class="text-danger small font-italic"></span>
								</div>

								<div class="col-12 form-group mb-4">
									<label asp-for="TongSoGhe" class="font-weight-bold text-dark">Tổng sức chứa (Số lượng ghế)</label>
									<div class="input-group">
										<div class="input-group-prepend">
											<span class="input-group-text bg-light"><i class="fas fa-users"></i></span>
										</div>
										<input asp-for="TongSoGhe" class="form-control font-weight-bold text-primary" type="number" min="1" />
									</div>
									<span asp-validation-for="TongSoGhe" class="text-danger small font-italic"></span>
									<small class="form-text text-muted">Số lượng ghế được phép đặt trên tàu.</small>
								</div>

								<div class="col-12 form-group mb-0">
									<div class="custom-control custom-switch custom-switch-lg">
										<input type="checkbox" class="custom-control-input" asp-for="TrangThai" id="statusSwitch">
										<label class="custom-control-label font-weight-bold text-success" for="statusSwitch">Sẵn sàng vận hành</label>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="card-footer bg-light d-flex justify-content-between py-3">
					<a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
						<span class="icon text-white-50">
							<i class="fas fa-arrow-left"></i>
						</span>
						<span class="text">Danh sách tàu</span>
					</a>

					<button type="submit" class="btn btn-warning btn-icon-split shadow-sm font-weight-bold">
						<span class="icon text-white-50">
							<i class="fas fa-save"></i>
						</span>
						<span class="text">Lưu thay đổi</span>
					</button>
				</div>
			</form>

			<p class="mb-5 small text-muted text-center">
				<i class="fas fa-info-circle mr-1"></i> Lưu ý: Mọi thay đổi sẽ ảnh hưởng trực tiếp đến lịch trình và việc đặt chỗ.
			</p>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

	<script>
		// Xử lý hiển thị tên file và preview ảnh ngay lập tức
		$('.custom-file-input').on('change', function(e) {
			let fileName = $(this).val().split('\\').pop();
			$(this).next('.custom-file-label').addClass("selected").html(fileName || "Thay đổi ảnh mới...");

			const file = e.target.files[0];
			if (file) {
				const reader = new FileReader();
				reader.onload = function(e) {
					// Cập nhật trực tiếp vào ảnh hiện tại để người dùng thấy sự thay đổi
					$('#imgPreview').attr('src', e.target.result).css('border', '2px dashed #f6c23e');
				}
				reader.readAsDataURL(file);
			}
		});
	</script>
}
@model WebAppBookingBoat.ViewModels.TauViewModel

@{
    ViewData["Title"] = "Chỉnh sửa tàu";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Cập nhật thông tin</h1>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <form asp-action="Edit" enctype="multipart/form-data" class="shadow-sm p-4 border rounded bg-white">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @* 1. Quan trọng: Giữ lại ID và Tên ảnh cũ *@
            <input type="hidden" asp-for="MaTau" />
            <input type="hidden" asp-for="HinhAnhCu" /> @* Sửa từ HinhAnh thành HinhAnhCu *@

            @* 2. Tên tàu *@
            <div class="form-group mb-4">
                <label asp-for="TenTau" class="control-label fw-bold mb-1 d-block"></label>
                <input asp-for="TenTau" class="form-control" />
                <span asp-validation-for="TenTau" class="text-danger"></span>
            </div>

            @* 3. Xử lý ảnh hiện tại và ảnh mới *@
            <div class="form-group mb-4">
                <div class="row">
                    <div class="col-md-4">
                        <label class="fw-bold mb-1 d-block text-muted">Ảnh hiện tại</label>
                        <div class="mb-2">
                            @if (!string.IsNullOrEmpty(Model.HinhAnhCu))
                            {
                                <img src="~/images/tau/@Model.HinhAnhCu" width="150" class="img-thumbnail" alt="Ảnh tàu" />
                            }
                            else
                            {
                                <img src="~/images/tau/default-boat.jpg" width="150" class="img-thumbnail" alt="Ảnh mặc định" />
                            }
                        </div>
                    </div>

                    <div class="col-md-8 border-left">
                        <label class="fw-bold mb-1 d-block text-primary">Ảnh mới sẽ thay đổi</label>
                        <div class="mb-2">
                            @* Ban đầu ẩn đi hoặc để trống, khi chọn file sẽ hiện ra *@
                            <img id="imgPreviewEdit" src="#" class="img-thumbnail shadow-sm d-none"
                                 style="width: 150px; height: 100px; object-fit: cover; border: 2px dashed #4e73df;"
                                 alt="Ảnh mới preview" />
                        </div>
                        <input asp-for="ImageFile" id="imageInputEdit" type="file" class="form-control" accept="image/*" />
                        <small class="text-muted">Chọn ảnh mới nếu muốn thay đổi ảnh hiện tại.</small>
                        <span asp-validation-for="ImageFile" class="text-danger"></span>
                    </div>
                </div>
            </div>

            @* 4. Ghế thường *@
            <div class="form-group mb-4">
                <label asp-for="SoGheThuong" class="control-label fw-bold mb-1 d-block"></label>
                <input asp-for="SoGheThuong" class="form-control" id="SoGheThuong" />
                <span asp-validation-for="SoGheThuong" class="text-danger"></span>
            </div>

            @* 5. Ghế VIP *@
            <div class="form-group mb-4">
                <label asp-for="SoGheVIP" class="control-label fw-bold mb-1 d-block"></label>
                <input asp-for="SoGheVIP" class="form-control" id="SoGheVIP" />
                <span asp-validation-for="SoGheVIP" class="text-danger"></span>
            </div>

            @* 6. Tổng số ghế *@
            <div class="form-group mb-4">
                <label asp-for="TongSoGhe" class="control-label fw-bold mb-1 d-block text-danger"></label>
                <input asp-for="TongSoGhe" class="form-control bg-light" id="TongSoGhe" readonly />
                <small class="text-muted">Tự động cập nhật dựa trên số ghế thành phần</small>
            </div>

            @* 7. Trạng thái *@
            <div class="form-group mb-4 form-check">
                <input class="form-check-input" asp-for="TrangThai" />
                <label class="form-check-label fw-bold" asp-for="TrangThai">Đang hoạt động</label>
            </div>

            <hr />

            <div class="form-group d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại</a>
                <button type="submit" class="btn btn-primary px-5">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/tau-logic.js"></script>
}
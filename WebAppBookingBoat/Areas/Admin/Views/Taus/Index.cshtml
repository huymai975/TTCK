@model IEnumerable<WebAppBookingBoat.Models.Tau>

@{
    ViewData["Title"] = "Index";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Danh sách tàu thuyền</h1>
        <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-download fa-sm text-white-50"></i> Xuất báo cáo
        </a>
    </div>
</div>

<div class="container">
<p>
        <a asp-action="Create" class="btn btn-success">
            Thêm mới
        </a>
</p>

<table class="table">
    <thead>
        <tr>
            <th scope="col">@Html.DisplayNameFor(model => model.MaTau)</th>
            <th scope="col">@Html.DisplayNameFor(model => model.TenTau)</th>
            <th scope="col">@Html.DisplayNameFor(model => model.HinhAnh)</th>
            <th scope="col"> @Html.DisplayNameFor(model => model.TongSoGhe)</th>
            <th scope="col">@Html.DisplayNameFor(model => model.SoGheThuong)</th>
            <th scope="col"> @Html.DisplayNameFor(model => model.SoGheVIP)</th>
            <th scope="col">@Html.DisplayNameFor(model => model.TrangThai)</th>
            <th scope="col">Hành động</th>
        </tr>
    </thead>      

        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">
                    @Html.DisplayFor(modelItem => item.MaTau)
                </th>
                <td>
                    @Html.DisplayFor(modelItem => item.TenTau)
                </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.HinhAnh))
                        {
                            <img src="~/images/tau/@item.HinhAnh" width="100" class="img-thumbnail" alt="Ảnh tàu" />
                        }
                        else
                        {
                            <img src="~/images/tau/default-boat.jpg" width="100" class="img-thumbnail" alt="No image" />
                        }
                    </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TongSoGhe)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SoGheThuong)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SoGheVIP)
                </td>
                    <td>
                        @if (item.TrangThai)
                        {
                            <span class="badge badge-success px-2 py-1">Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="badge badge-danger px-2 py-1">Tạm ngưng</span>
                        }
                    </td>
                <td>
                        <a asp-action="Edit" asp-route-id="@item.MaTau" class="btn btn-warning">Sửa</a> 
                        <a asp-action="Details" asp-route-id="@item.MaTau" class="btn btn-primary">Chi tiết</a> 
                        <a asp-action="Delete" asp-route-id="@item.MaTau" class="btn btn-danger" >Xóa</a>
                </td>
            </tr>
        } 
        </tbody>
    </table>
    <!-- Content here -->
</div>

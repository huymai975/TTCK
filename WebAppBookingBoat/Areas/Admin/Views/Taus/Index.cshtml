@model IEnumerable<WebAppBookingBoat.Models.Tau>

@{
    ViewData["Title"] = "Quản lý Đội Tàu";
}

<style>
    /* 1. KHUNG BẢNG & TỈ LỆ CỘT */
    #dataTable {
        table-layout: fixed;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .col-id {
        width: 60px;
    }

    .col-img {
        width: 120px;
    }

    .col-capacity {
        width: 100px;
    }

    .col-status {
        width: 150px;
    }

    .col-action {
        width: 130px;
    }

    /* 2. STYLE NỘI DUNG */
    .text-name-ship {
        display: block;
        font-weight: 700;
        color: #2c3e50;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.95rem;
    }

    /* 3. NÚT THAO TÁC */
    .btn-modern {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s ease;
        margin: 0 2px;
        text-decoration: none !important;
        border: none;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-edit {
        background-color: #fff8e1;
        color: #f57f17;
    }

    .btn-delete {
        background-color: #ffebee;
        color: #c62828;
    }

    .btn-edit:hover {
        background-color: #f57f17;
        color: #fff;
    }

    .btn-delete:hover {
        background-color: #c62828;
        color: #fff;
    }

    /* 4. BADGE TRẠNG THÁI */
    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        display: inline-block;
        width: 100%;
        text-align: center;
        cursor: pointer;
        border: none;
        transition: opacity 0.2s;
    }

        .badge-status:hover {
            opacity: 0.8;
        }

    .pagination .page-item.active .page-link {
        background-color: #4e73df;
        border-color: #4e73df;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-ship text-primary mr-2"></i>Quản lý Đội Tàu
        </h1>
    </div>

    <div class="mb-3 d-flex">
        <a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
            <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
            <span class="text font-weight-bold">Thêm tàu mới</span>
        </a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header py-3 bg-white border-bottom">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                <i class="fas fa-list mr-1"></i> Danh sách đội tàu
            </h6>
        </div>

        <div class="card-body p-0">
            <div class="px-3 pt-3">
                <div class="card shadow-sm border-0" style="background-color: #f8f9fc;">
                    <div class="card-body py-2">
                        <div class="d-flex align-items-center flex-wrap">
                            <div class="input-group input-group-sm shadow-sm mr-2" style="width: 220px;">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-info text-white border-0"><i class="fas fa-toggle-on"></i></span>
                                </div>
                                <select id="statusFilter" class="form-control border-0 font-weight-bold text-info">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="Hoạt động">Hoạt động</option>
                                    <option value="Tạm dừng">Tạm dừng</option>
                                </select>
                            </div>
                            <a asp-action="Index" class="btn btn-sm btn-outline-secondary border-0 rounded-circle shadow-sm bg-white" title="Làm mới">
                                <i class="fas fa-sync-alt"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive mt-2">
                <table class="table table-hover align-middle mb-0" id="dataTable">
                    <thead class="bg-light text-muted small font-weight-bold">
                        <tr>
                            <th class="text-center col-id border-0">ID</th>
                            <th class="border-0">Thông tin tàu</th>
                            <th class="text-center col-img border-0">Hình ảnh</th>
                            <th class="text-center col-capacity border-0">Sức chứa</th>
                            <th class="text-center col-status border-0">Trạng thái</th>
                            <th class="text-center col-action border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center font-weight-bold text-gray-500 small align-middle">
                                    #@item.MaTau.ToString("D3")
                                </td>
                                <td class="align-middle">
                                    <span class="text-name-ship">@item.TenTau</span>
                                    <small class="text-muted font-weight-bold">CODE: BOAT-@item.MaTau</small>
                                </td>
                                <td class="text-center align-middle">
                                    <img src="/images/tau/@item.HinhAnh" width="80" class="rounded shadow-sm border" style="height: 45px; object-fit: cover;" />
                                </td>
                                <td class="text-center align-middle font-weight-bold text-primary">
                                    @item.TongSoGhe
                                </td>
                                <td class="text-center align-middle td-status" data-search="@(item.TrangThai ? "Hoạt động" : "Tạm dừng")">
                                    <div class="status-toggle" data-id="@item.MaTau" style="cursor:pointer">
                                        @if (item.TrangThai)
                                        {
                                            <span class="badge badge-status badge-success shadow-sm"><i class="fas fa-check-circle mr-1"></i>Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-status badge-secondary shadow-sm"><i class="fas fa-pause-circle mr-1"></i>Tạm dừng</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-center align-middle">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Edit" asp-route-id="@item.MaTau" class="btn-modern btn-edit" title="Sửa"><i class="fas fa-edit"></i></a>
                                        <button type="button" class="btn-modern btn-delete" onclick="deleteShip(@item.MaTau, '@item.TenTau')" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function() {
            var table = $('#dataTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
                    "searchPlaceholder": "Tìm tên tàu..."
                },
                "pageLength": 10,
                "order": [[0, "desc"]],
                "dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            $('#statusFilter').on('change', function() {
                table.column(4).search($(this).val()).draw();
            });

            // Toggle Status AJAX - Khắc phục lỗi click nhiều lần và lỗi filter
            $('#dataTable').on('click', '.status-toggle', function () {
                var $container = $(this);
                var id = $container.data('id');
                var $td = $container.closest('td');

                $.post('@Url.Action("ToggleStatus")', { id: id }, function (res) {
                    if (res.success) {
                        var textStatus = res.newState ? "Hoạt động" : "Tạm dừng";
                        var badgeClass = res.newState ? "badge-success" : "badge-secondary";
                        var icon = res.newState ? "fa-check-circle" : "fa-pause-circle";

                        var newHtml = `
                            <div class="status-toggle" data-id="${id}" style="cursor:pointer">
                                <span class="badge badge-status ${badgeClass} shadow-sm">
                                    <i class="fas ${icon} mr-1"></i>${textStatus}
                                </span>
                            </div>`;

                        // Cập nhật giá trị search cho DataTable và vẽ lại ô đó
                        $td.attr('data-search', textStatus);
                        table.cell($td).data(newHtml).draw(false);

                        const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
                        Toast.fire({ icon: 'success', title: 'Cập nhật trạng thái thành công' });
                    }
                });
            });
        });

        function deleteShip(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Tàu [" + name + "] sẽ bị xóa vĩnh viễn!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e74a3b',
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire('Thành công', res.message, 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Lỗi', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}
@model WebAppBookingBoat.Models.NhanVien

@{
    ViewData["Title"] = "Cập nhật hồ sơ nhân sự";
}

<head>
    <style>
        /* Giữ nguyên CSS cũ của Huy */
        .border-left-warning {
            border-left: 4px solid #f6c23e !important;
        }

        .form-control:focus {
            border-color: #f6c23e;
            box-shadow: 0 0 0 0.2rem rgba(246, 194, 62, 0.15);
        }
    </style>
</head>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-user-edit text-warning mr-2"></i>Điều chỉnh hồ sơ nhân sự
        </h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            <form asp-action="Edit" method="post" class="card shadow-lg mb-4 border-left-warning">
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary text-uppercase">
                        Mã nhân viên: #@Model.MaNV
                    </h6>
                    <span class="badge badge-warning text-white p-2 shadow-sm">
                        <i class="fas fa-sync-alt mr-1"></i> Hiệu chỉnh thông tin nội bộ
                    </span>
                </div>

                <div class="card-body px-lg-5 py-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small shadow-sm"></div>

                    @* Hidden fields *@
                    <input type="hidden" asp-for="MaNV" />

                    <div class="row">
                        <div class="col-md-6 border-right">
                            <h6 class="font-weight-bold text-dark mb-3"><i class="fas fa-id-card mr-2 text-warning"></i>Thông tin cá nhân</h6>

                            <div class="form-group mb-4">
                                <label asp-for="HoTen" class="small font-weight-bold text-muted text-uppercase">Họ và Tên</label>
                                <input asp-for="HoTen" class="form-control shadow-sm" />
                                <span asp-validation-for="HoTen" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Sdt" class="small font-weight-bold text-muted text-uppercase">Số điện thoại</label>
                                <input asp-for="Sdt" class="form-control shadow-sm" />
                                <span asp-validation-for="Sdt" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Email" class="small font-weight-bold text-muted text-uppercase">Địa chỉ Email</label>
                                <input asp-for="Email" class="form-control shadow-sm" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 pl-md-4">
                            <h6 class="font-weight-bold text-dark mb-3"><i class="fas fa-briefcase mr-2 text-warning"></i>Vị trí & Lương thưởng</h6>

                            <div class="form-group mb-4">
                                <label asp-for="ChucVu" class="small font-weight-bold text-muted text-uppercase">Chức vụ</label>
                                <input asp-for="ChucVu" class="form-control shadow-sm" />
                                <span asp-validation-for="ChucVu" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label class="small font-weight-bold text-muted text-uppercase">Mức lương (VNĐ)</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-light"><i class="fas fa-money-bill-wave text-success"></i></span>
                                    </div>
                                    @* Ô này chỉ để hiển thị, không có name để không gửi về Controller *@
                                    <input type="text" id="LuongDisplay"
                                           value="@(Model.Luong > 0 ? ((long)Model.Luong).ToString() : "0")"
                                           class="form-control shadow-sm font-weight-bold text-success" />

                                    @* Ô ẩn này mới là ô thực sự map với Model *@
                                    <input type="hidden" asp-for="Luong" id="LuongActual" />
                                </div>
                                <span asp-validation-for="Luong" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="MaTK" class="small font-weight-bold text-muted text-uppercase">Tài khoản</label>
                                <select asp-for="MaTK" class="form-control shadow-sm" asp-items="ViewBag.MaTK">
                                    <option value="">-- Chưa gán tài khoản --</option>
                                </select>
                            </div>

                            <div class="custom-control custom-switch mt-4">
                                <input type="checkbox" class="custom-control-input" asp-for="TrangThai" id="statusSwitch">
                                <label class="custom-control-label font-weight-bold text-dark" for="statusSwitch">
                                    @(Model.TrangThai ? "Đang làm việc" : "Đã nghỉ việc")
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light d-flex justify-content-between py-3">
                    <a asp-action="Index" class="btn btn-secondary shadow-sm">Hủy thay đổi</a>
                    <button type="submit" class="btn btn-warning shadow-sm font-weight-bold text-white">Lưu cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // Cho phép validate cả ô ẩn
            if ($.validator) {
                $.validator.setDefaults({ ignore: [] });

                // Ghi đè lại hàm check số để chấp nhận định dạng thuần
                $.validator.methods.number = function (value, element) {
                    return this.optional(element) || /^-?\d+$/.test(value);
                };
            }

            const luongDisplay = $('#LuongDisplay');
            const luongActual = $('#LuongActual');

            function formatCurrency(n) {
                if (!n) return "";
                let value = n.toString().replace(/\D/g, "").replace(/^0+/, "");
                return value.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
            }

            // 1. Khi người dùng gõ vào ô hiển thị
            luongDisplay.on('input', function () {
                let raw = $(this).val().replace(/\D/g, "");
                luongActual.val(raw);
                $(this).val(formatCurrency(raw));
            });

            // 2. Lúc load trang
            if (luongDisplay.val()) {
                let initialValue = luongDisplay.val().replace(/\D/g, "");
                luongActual.val(initialValue);
                luongDisplay.val(formatCurrency(initialValue));
            }

            // 3. Xử lý trước khi Submit
            $('form').on('submit', function () {
                if (!luongActual.val() && luongDisplay.val()) {
                    luongActual.val(luongDisplay.val().replace(/\D/g, ""));
                }
                $('select:disabled').prop('disabled', false);
            });

            // 4. Cập nhật label cho Switch
            $('#trangThaiSwitch').on('change', function() {
                $(this).next('label').text($(this).is(':checked') ? 'Đang làm việc' : 'Đã nghỉ việc');
            });
        }); // Kết thúc document.ready
    </script>
}
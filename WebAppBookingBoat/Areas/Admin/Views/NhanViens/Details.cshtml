@model WebAppBookingBoat.Models.NhanVien

@{
    ViewData["Title"] = "Hồ sơ chi tiết nhân viên";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-user-check text-info mr-2"></i>Hồ sơ nhân viên
        </h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            <div class="card shadow-lg mb-4 border-left-info">
                @* Card Header *@
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-info text-uppercase">Mã nhân viên: #@Model.MaNV</h6>
                    <span class="badge badge-light border text-muted shadow-sm px-3 py-2">
                        <i class="fas fa-calendar-alt mr-1"></i> Ngày xem: @DateTime.Now.ToString("dd/MM/yyyy")
                    </span>
                </div>

                <div class="card-body">
                    <div class="row">
                        @* Cột trái: Thông tin cá nhân *@
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-dark mb-4 border-bottom pb-2">
                                <i class="fas fa-id-card mr-2 text-info"></i>Thông tin cá nhân
                            </h5>

                            <div class="mb-4 text-center">
                                @* Avatar mặc định cho chuyên nghiệp *@
                                <div class="mb-3">
                                    <i class="fas fa-user-circle fa-5x text-gray-300"></i>
                                </div>
                                <div class="h4 font-weight-bold text-primary mb-1">@Model.HoTen</div>
                                <div class="badge @(Model.TrangThai ? "badge-success" : "badge-secondary") px-3 py-2 rounded-pill">
                                    @(Model.TrangThai ? "Đang làm việc" : "Đã nghỉ việc")
                                </div>
                            </div>

                            <div class="p-3 bg-light rounded shadow-sm">
                                <div class="mb-2">
                                    <label class="small font-weight-bold text-muted text-uppercase d-block mb-0">Số điện thoại</label>
                                    <span class="text-dark">@Model.Sdt</span>
                                </div>
                                <div class="mb-0">
                                    <label class="small font-weight-bold text-muted text-uppercase d-block mb-0">Địa chỉ Email</label>
                                    <span class="text-dark">@Model.Email</span>
                                </div>
                            </div>
                        </div>

                        @* Cột phải: Công việc & Tài khoản *@
                        <div class="col-md-6 pl-md-4">
                            <h5 class="font-weight-bold text-dark mb-4 border-bottom pb-2">
                                <i class="fas fa-briefcase mr-2 text-info"></i>Công việc & Tài khoản
                            </h5>

                            <div class="mb-4">
                                <div class="p-3 bg-light rounded border-left-primary mb-3 shadow-sm">
                                    <label class="small font-weight-bold text-primary text-uppercase d-block mb-1">Chức vụ hiện tại</label>
                                    <div class="h5 font-weight-bold mb-0">@Model.ChucVu</div>
                                </div>

                                <div class="p-3 bg-light rounded border-left-success mb-3 shadow-sm">
                                    <label class="small font-weight-bold text-success text-uppercase d-block mb-1">Mức lương (VNĐ)</label>
                                    <div class="h5 font-weight-bold mb-0 text-success">@Model.Luong.ToString("N0") đ</div>
                                </div>
                            </div>

                            <div class="card bg-gray-100 border-0 shadow-sm">
                                <div class="card-body">
                                    <label class="small font-weight-bold text-muted text-uppercase d-block mb-2">Tài khoản hệ thống liên kết</label>
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-user-shield text-info fa-2x mr-3"></i>
                                        <div>
                                            <div class="font-weight-bold text-dark">@(Model.AppUser?.UserName ?? "Chưa liên kết")</div>
                                            <div class="text-xs text-muted">ID: @(Model.AppUser?.Id ?? "N/A")</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Card Footer *@
                <div class="card-footer bg-light d-flex justify-content-between py-3">
                    <a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-left"></i>
                        </span>
                        <span class="text">Quay lại danh sách</span>
                    </a>

                    <a asp-action="Edit" asp-route-id="@Model.MaNV" class="btn btn-warning btn-icon-split shadow-sm font-weight-bold">
                        <span class="icon text-white-50">
                            <i class="fas fa-user-edit"></i>
                        </span>
                        <span class="text">Chỉnh sửa hồ sơ</span>
                    </a>
                </div>
            </div>

            <p class="mb-5 small text-muted text-center italic">
                <i class="fas fa-info-circle mr-1"></i> Đây là dữ liệu hồ sơ nhân sự nội bộ của hệ thống WebAppBookingBoat.
            </p>
        </div>
    </div>
</div>

<style>
    .border-left-info {
        border-left: 4px solid #36b9cc !important;
    }

    .border-left-primary {
        border-left: 4px solid #4e73df !important;
    }

    .border-left-success {
        border-left: 4px solid #1cc88a !important;
    }

    .bg-light {
        background-color: #f8f9fc !important;
    }

    .bg-gray-100 {
        background-color: #f8f9fc !important;
    }

    .italic {
        font-style: italic;
    }
</style>
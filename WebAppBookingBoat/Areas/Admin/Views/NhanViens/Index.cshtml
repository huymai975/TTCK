@using System.Text.RegularExpressions
@model IEnumerable<WebAppBookingBoat.Models.NhanVien>

@{
	ViewData["Title"] = "Quản lý Nhân viên";
}

<style>
	/* 1. KHUNG BẢNG & TỈ LỆ CỘT */
	#dataTable {
		table-layout: fixed;
		width: 100% !important;
		border-collapse: separate;
		border-spacing: 0;
	}

	.col-id {
		width: 50px;
	}

	.col-info {
		width: auto;
	}

	.col-contact {
		width: 180px;
	}

	.col-account {
		width: 150px;
	}

	.col-salary {
		width: 160px;
	}

	.col-status {
		width: 130px;
	}

	.col-action {
		width: 130px;
	}

	/* 2. STYLE NỘI DUNG */
	.text-name-main {
		display: block;
		font-weight: 700;
		color: #2c3e50;
		line-height: 1.3;
		font-size: 0.95rem;
	}

	/* 3. NÚT THAO TÁC (SOFT UI) */
	.btn-modern {
		width: 32px;
		height: 32px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 8px;
		transition: all 0.2s ease;
		margin: 0 2px;
		text-decoration: none !important;
	}

		.btn-modern:hover {
			transform: translateY(-2px);
			box-shadow: 0 4px 8px rgba(0,0,0,0.1);
		}

	.btn-view {
		background-color: #e1f5fe;
		color: #039be5;
	}

	.btn-edit {
		background-color: #fff8e1;
		color: #f57f17;
	}

	.btn-delete {
		background-color: #ffebee;
		color: #c62828;
	}

	.btn-lock {
		background-color: #f5f5f5;
		color: #9e9e9e;
		cursor: not-allowed;
	}

	.btn-view:hover {
		background-color: #039be5;
		color: #fff;
	}

	.btn-edit:hover {
		background-color: #f57f17;
		color: #fff;
	}

	.btn-delete:hover {
		background-color: #c62828;
		color: #fff;
	}

	.badge-status {
		padding: 6px 12px;
		border-radius: 8px;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
	}
</style>

<div class="container-fluid">
	<div class="d-sm-flex align-items-center justify-content-between mb-4">
		<h1 class="h3 mb-0 text-gray-800 font-weight-bold">
			<i class="fas fa-user-tie text-primary mr-2"></i>Quản lý Nhân viên
		</h1>
	</div>

	<div class="mb-3">
		<a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
			<span class="icon text-white-50"><i class="fas fa-plus"></i></span>
			<span class="text font-weight-bold">Thêm nhân viên mới</span>
		</a>
	</div>

	<div class="card shadow-sm mb-4 border-0">
		<div class="card-header py-3 bg-white border-bottom">
			<h6 class="m-0 font-weight-bold text-primary text-uppercase small">
				<i class="fas fa-list mr-1"></i> Danh sách đội ngũ nhân sự
			</h6>
		</div>

		<div class="card-body p-0">
			<div class="px-3 pt-3">
				<div class="card shadow-sm border-0" style="background-color: #f8f9fc;">
					<div class="card-body py-2">
						<div class="d-flex align-items-center flex-wrap">
							<div class="input-group input-group-sm shadow-sm mr-2" style="width: 250px;">
								<div class="input-group-prepend">
									<span class="input-group-text bg-info text-white border-0"><i class="fas fa-filter"></i></span>
								</div>
								<select id="statusFilter" class="form-control border-0 font-weight-bold text-info">
									<option value="">Tất cả trạng thái</option>
									<option value="Đang làm việc">Đang làm việc</option>
									<option value="Đã nghỉ việc">Đã nghỉ việc</option>
								</select>
							</div>
							<button id="btnResetFilter" class="btn btn-sm btn-outline-secondary border-0 rounded-circle shadow-sm bg-white" title="Làm mới">
								<i class="fas fa-sync-alt"></i>
							</button>
						</div>
					</div>
				</div>
			</div>

			<div class="table-responsive mt-2">
				<table class="table table-hover align-middle mb-0" id="dataTable">
					<thead class="bg-light text-muted small font-weight-bold">
						<tr>
							<th class="text-center col-id border-0">ID</th>
							<th class="col-info border-0">Họ tên & Email</th>
							<th class="col-contact border-0">Liên lạc</th>
							<th class="col-account border-0">Tài khoản</th>
							<th class="text-right col-salary border-0">Mức lương</th>
							<th class="text-center col-status border-0">Trạng thái</th>
							<th class="text-center col-action border-0">Thao tác</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model)
						{
							<tr>
								<td class="text-center font-weight-bold text-gray-500 small">#@item.MaNV</td>
								<td>
									<span class="text-name-main">@item.HoTen</span>
									<small class="text-muted"><i class="far fa-envelope mr-1"></i>@item.Email</small>
								</td>
								<td class="text-center">
									@if (!string.IsNullOrEmpty(item.Sdt))
									{
										@* Định dạng thành: 0908 456 789 *@
										<span class="font-weight-bold text-dark">
											<i class="fas fa-phone-alt mr-1 small text-muted"></i>
											@Regex.Replace(item.Sdt, @"(\d{4})(\d{3})(\d{3})", "$1 $2 $3")
										</span>
									}
									else
									{
										<span class="text-muted small italic">Chưa cập nhật</span>
									}
								</td>
								<td>
									@if (item.AppUser != null)
									{
										<div class="badge badge-light border p-2 w-100 text-left shadow-sm">
											<i class="fas fa-user-circle mr-1 @(item.AppUser.TrangThai ? "text-success" : "text-danger")"></i>
											@item.AppUser.UserName
										</div>
									}
									else
									{
										<span class="text-muted small italic">Chưa cấp TK</span>
									}
								</td>
								<td class="text-right font-weight-bold text-primary">
									@item.Luong.ToString("N0")đ
								</td>
								<td class="text-center">
									@if (item.TrangThai)
									{
										<span class="badge badge-status shadow-sm badge-success">Đang làm việc</span>
									}
									else
									{
										<span class="badge badge-status shadow-sm badge-danger">Đã nghỉ việc</span>
									}
								</td>
								<td class="text-center">
									<div class="d-flex justify-content-center">
										<a asp-action="Details" asp-route-id="@item.MaNV" class="btn-modern btn-view" title="Chi tiết"><i class="fas fa-eye"></i></a>

										@if (item.TrangThai)
										{
											<a asp-action="Edit" asp-route-id="@item.MaNV" class="btn-modern btn-edit" title="Sửa"><i class="fas fa-edit"></i></a>
											<button type="button" class="btn-modern btn-delete" onclick="deleteNhanVienAjax(@item.MaNV, '@item.HoTen')" title="Xóa">
												<i class="fas fa-trash"></i>
											</button>
										}
										else
										{
											<span class="btn-modern btn-lock" title="Đã khóa"><i class="fas fa-lock"></i></span>
										}
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
	<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
	<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
	<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

	<script>
		var table;

		$(document).ready(function() {
			// 1. Khởi tạo DataTable
			table = $('#dataTable').DataTable({
				"language": {
					"url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
					"search": "Tìm nhanh:",
					"searchPlaceholder": "Tên, email, SĐT...",
					"paginate": {
						"previous": "<i class='fas fa-angle-left'></i>",
						"next": "<i class='fas fa-angle-right'></i>",
						"first": "<i class='fas fa-angle-double-left'></i>",
						"last": "<i class='fas fa-angle-double-right'></i>"
					}
				},
				"pageLength": 10,
				"order": [[0, "desc"]],
				"dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
						"<'row'<'col-sm-12'tr>>" +
						"<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
				"columnDefs": [
					{ "orderable": false, "targets": 6 }
				]
			});

			// 2. Bộ lọc trạng thái
			$('#statusFilter').on('change', function() {
				var val = $(this).val();
				table.column(5).search(val).draw();
			});

			// 3. Nút Reset
			$('#btnResetFilter').on('click', function() {
				$('#statusFilter').val('');
				table.search('').column(5).search('').draw();
			});
		});

		// 4. Hàm xóa AJAX (Đưa ra ngoài document.ready để nút onclick gọi được)
		function deleteNhanVienAjax(id, name) {
			Swal.fire({
				title: 'Xác nhận xóa?',
				text: `Hệ thống sẽ xóa hoặc cho nghỉ việc nhân viên: ${name}`,
				icon: 'warning',
				showCancelButton: true,
				confirmButtonColor: '#e74a3b',
				cancelButtonColor: '#858796',
				confirmButtonText: 'Xác nhận',
				cancelButtonText: 'Hủy'
			}).then((result) => {
				if (result.isConfirmed) {
					$.ajax({
						url: '@Url.Action("Delete", "NhanViens")',
						type: 'POST',
						data: {
							id: id,
							"__RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
						},
						success: function (response) {
							if (response.success) {
								Swal.fire({
									title: 'Thành công!',
									text: response.message,
									icon: 'success',
									timer: 1500,
									showConfirmButton: false
								}).then(() => {
									location.reload();
								});
							} else {
								Swal.fire('Lỗi!', response.message, 'error');
							}
						},
						error: function () {
							Swal.fire('Lỗi!', 'Không thể thực hiện yêu cầu này.', 'error');
						}
					});
				}
			});
		}
	</script>
}
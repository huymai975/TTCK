@model WebAppBookingBoat.Models.KhachHang

@{
    ViewData["Title"] = "Thêm mới Khách hàng";
}

<head>
    <style>
        .border-left-primary {
            border-left: 4px solid #4e73df !important;
        }

        .border-left-success {
            border-left: 4px solid #1cc88a !important;
        }

        .border-left-info {
            border-left: 4px solid #36b9cc !important;
        }

        .form-control:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.2);
        }

        .input-group-text {
            background-color: #f8f9fc;
            border-right: none;
        }

        .form-control-prepended {
            border-left: none !important;
        }
    </style>
</head>

<div class="container-fluid">
    @* Tiêu đề trang *@
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-user-plus text-success mr-2"></i>Đăng ký Khách hàng mới
        </h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            <form asp-action="Create" method="post" class="card shadow-lg mb-4 border-left-success">
                @* Card Header *@
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-success text-uppercase">
                        Nhập thông tin hồ sơ
                    </h6>
                    <span class="badge badge-success text-white p-2 shadow-sm">
                        <i class="fas fa-keyboard mr-1"></i> Form nhập liệu
                    </span>
                </div>

                <div class="card-body px-lg-5 py-4">
                    @* Tóm tắt lỗi nếu có *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small shadow-sm" role="alert"></div>

                    <div class="row">
                        @* Cột 1: Thông tin định danh *@
                        <div class="col-md-6 border-right">
                            <h6 class="font-weight-bold text-dark mb-4 text-center">
                                <i class="fas fa-id-card-alt mr-2 text-success"></i>Thông tin cá nhân
                            </h6>

                            <div class="form-group mb-4">
                                <label asp-for="HoTen" class="small font-weight-bold text-muted text-uppercase">Họ và Tên khách hàng</label>
                                <div class="input-group shadow-sm">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fas fa-user text-success"></i></span>
                                    </div>
                                    <input asp-for="HoTen" class="form-control form-control-prepended" placeholder="Ví dụ: Nguyễn Văn A" />
                                </div>
                                <span asp-validation-for="HoTen" class="text-danger small mt-1"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="NgaySinh" class="small font-weight-bold text-muted text-uppercase">Ngày sinh</label>
                                <input asp-for="NgaySinh" type="date" class="form-control shadow-sm border-left-info" />
                                <span asp-validation-for="NgaySinh" class="text-danger small mt-1"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="MaTK" class="small font-weight-bold text-muted text-uppercase">Liên kết tài khoản (Nếu có)</label>
                                <select asp-for="MaTK" class="form-control border-left-primary shadow-sm" asp-items="ViewBag.MaTK">
                                    <option value="">-- Khách vãng lai (Chưa có tài khoản) --</option>
                                </select>
                                <small class="text-info"><i class="fas fa-info-circle mr-1"></i>Chỉ hiển thị các tài khoản chưa được gán.</small>
                            </div>
                        </div>

                        @* Cột 2: Thông tin liên lạc *@
                        <div class="col-md-6 pl-md-4">
                            <h6 class="font-weight-bold text-dark mb-4 text-center">
                                <i class="fas fa-address-book mr-2 text-success"></i>Thông tin liên hệ
                            </h6>

                            <div class="form-group mb-4">
                                <label asp-for="Sdt" class="small font-weight-bold text-muted text-uppercase">Số điện thoại</label>
                                <div class="input-group shadow-sm">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fas fa-phone text-primary"></i></span>
                                    </div>
                                    <input asp-for="Sdt" class="form-control form-control-prepended" placeholder="0905xxxxxx" />
                                </div>
                                <span asp-validation-for="Sdt" class="text-danger small mt-1"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Email" class="small font-weight-bold text-muted text-uppercase">Địa chỉ Email</label>
                                <div class="input-group shadow-sm">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fas fa-envelope text-danger"></i></span>
                                    </div>
                                    <input asp-for="Email" class="form-control form-control-prepended" placeholder="name@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="DiaChi" class="small font-weight-bold text-muted text-uppercase">Địa chỉ cư trú</label>
                                <textarea asp-for="DiaChi" class="form-control shadow-sm border-left-success" rows="2" placeholder="Số nhà, tên đường..."></textarea>
                                <span asp-validation-for="DiaChi" class="text-danger small mt-1"></span>
                            </div>
                        </div>
                    </div>
                </div>

                @* Footer nút bấm *@
                <div class="card-footer bg-light d-flex justify-content-between py-3">
                    <a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
                        <span class="icon text-white-50"><i class="fas fa-arrow-left"></i></span>
                        <span class="text">Quay lại</span>
                    </a>

                    <button type="submit" class="btn btn-success btn-icon-split shadow-sm font-weight-bold">
                        <span class="icon text-white-50"><i class="fas fa-check-circle"></i></span>
                        <span class="text">Tạo khách hàng</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
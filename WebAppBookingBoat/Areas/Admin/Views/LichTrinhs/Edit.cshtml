@model WebAppBookingBoat.ViewModels.LichTrinhViewModel

@{
	ViewData["Title"] = "Cập nhật Lịch trình";
}

<head>
	<style>
		.border-left-primary {
			border-left: 4px solid #4e73df !important;
		}

		.border-left-info {
			border-left: 4px solid #36b9cc !important;
		}

		.border-left-warning {
			border-left: 4px solid #f6c23e !important;
		}

		.border-left-danger {
			border-left: 4px solid #e74a3b !important;
		}

		.border-left-success {
			border-left: 4px solid #1cc88a !important;
		}

		.form-control:focus {
			border-color: #f6c23e;
			box-shadow: 0 0 0 0.2rem rgba(246, 194, 62, 0.15);
		}
	</style>
</head>

<div class="container-fluid">
	@* Tiêu đề trang *@
	<div class="d-sm-flex align-items-center justify-content-between mb-4">
		<h1 class="h3 mb-0 text-gray-800 font-weight-bold">
			<i class="fas fa-edit text-warning mr-2"></i>Điều chỉnh Lịch trình
		</h1>
	</div>

	<div class="row justify-content-center">
		<div class="col-xl-10 col-lg-12">
			<form asp-action="Edit" method="post" class="card shadow-lg mb-4 border-left-warning">
				@* Card Header hiển thị mã lịch trình *@
				<div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
					<h6 class="m-0 font-weight-bold text-primary text-uppercase">
						Mã lịch trình: #@Model.MaLichTrinh
					</h6>
					<span class="badge badge-warning text-white p-2 shadow-sm">
						<i class="fas fa-clock mr-1"></i> Cập nhật thời gian & phương tiện
					</span>
				</div>

				<div class="card-body px-lg-5 py-4">
					<div asp-validation-summary="ModelOnly" class="alert alert-danger small shadow-sm" role="alert"></div>

					@* Hidden fields *@
					<input type="hidden" asp-for="MaLichTrinh" />

					<div class="row">
						@* Cột 1: Phân bổ và Giá vé *@
						<div class="col-md-6 border-right">
							<h6 class="font-weight-bold text-dark mb-3">
								<i class="fas fa-anchor mr-2 text-warning"></i>Cấu hình vận hành
							</h6>

							<div class="form-group mb-4">
								<label asp-for="MaTuyen" class="small font-weight-bold text-muted text-uppercase">Tuyến đường vận hành</label>
								<select asp-for="MaTuyen" class="form-control border-left-primary shadow-sm"
										asp-items="Model.DanhSachTuyen">
								</select>
								<span asp-validation-for="MaTuyen" class="text-danger small mt-1"></span>
							</div>

							<div class="form-group mb-4">
								<label asp-for="MaTau" class="small font-weight-bold text-muted text-uppercase">Phương tiện thực hiện</label>
								<select asp-for="MaTau" class="form-control border-left-info shadow-sm"
										asp-items="Model.DanhSachTau">
								</select>
								<span asp-validation-for="MaTau" class="text-danger small mt-1"></span>

								<div class="alert alert-info py-2 shadow-sm border-0">
									<small class="font-weight-bold">
										<i class="fas fa-info-circle mr-1"></i> Tình trạng ghế:
										<span class="text-primary">@Model.SoGheTrong trống</span> / @Model.TongSoGhe tổng số ghế thực tế.
									</small>
								</div>
							</div>
							<div class="form-group mb-4">
								<label asp-for="GiaVeCoBan" class="small font-weight-bold text-muted text-uppercase">Giá vé niêm yết (VNĐ)</label>
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text bg-light border-right-0"><i class="fas fa-money-bill-wave text-warning"></i></span>
									</div>
									@* Dùng duy nhất 1 input text để định dạng dấu phẩy giống bên Create *@
									<input asp-for="GiaVeCoBan" type="text" id="GiaVeDisplay"
										   value="@(Model.GiaVeCoBan > 0 ? ((long)Model.GiaVeCoBan).ToString() : "")"
										   class="form-control shadow-sm border-left-0"
										   placeholder="Ví dụ: 250,000" inputmode="numeric" />
								</div>
								<span asp-validation-for="GiaVeCoBan" class="text-danger small mt-1"></span>
							</div>
						</div>

						@* Cột 2: Thời gian và Trạng thái *@
						<div class="col-md-6 pl-md-4">
							<h6 class="font-weight-bold text-dark mb-3">
								<i class="fas fa-history mr-2 text-warning"></i>Lịch trình dự kiến
							</h6>

							<div class="form-group mb-4">
								<label asp-for="NgayGioKhoiHanh" class="small font-weight-bold text-muted text-uppercase">Giờ khởi hành</label>
								<input asp-for="NgayGioKhoiHanh" type="datetime-local" class="form-control shadow-sm border-left-warning" />
								<span asp-validation-for="NgayGioKhoiHanh" class="text-danger small mt-1"></span>
							</div>

							<div class="form-group mb-4">
								<label asp-for="NgayGioCapBenDuKien" class="small font-weight-bold text-muted text-uppercase">Giờ cập bến dự kiến</label>
								<input asp-for="NgayGioCapBenDuKien" type="datetime-local" class="form-control shadow-sm border-left-danger" />
								<span asp-validation-for="NgayGioCapBenDuKien" class="text-danger small mt-1"></span>
							</div>

							<div class="form-group mb-4">
								<label asp-for="TrangThai" class="small font-weight-bold text-muted text-uppercase">Cập nhật trạng thái</label>
								<select asp-for="TrangThai" class="form-control shadow-sm">
									<option value="Sắp khởi hành">Sắp khởi hành</option>
									<option value="Đang vận hành">Đang vận hành</option>
									<option value="Hoàn thành">Hoàn thành</option>
									<option value="Đã hủy">Đã hủy</option>
								</select>
								<span asp-validation-for="TrangThai" class="text-danger small mt-1"></span>
							</div>
						</div>
					</div>
				</div>

				@* Footer với các nút thao tác *@
				<div class="card-footer bg-light d-flex justify-content-between py-3">
					<a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
						<span class="icon text-white-50">
							<i class="fas fa-arrow-left"></i>
						</span>
						<span class="text">Hủy thay đổi</span>
					</a>

					<button type="submit" class="btn btn-warning btn-icon-split shadow-sm font-weight-bold">
						<span class="icon text-white-50">
							<i class="fas fa-save"></i>
						</span>
						<span class="text">Lưu cập nhật</span>
					</button>
				</div>
			</form>

			@* Cảnh báo thông tin *@
			<div class="alert alert-warning border-0 shadow-sm small">
				<i class="fas fa-exclamation-triangle mr-1"></i>
				<strong>Lưu ý quan trọng:</strong> Nếu bạn thay đổi <strong>Phương tiện (Tàu)</strong>, hệ thống sẽ tự động cập nhật lại <strong>Số ghế trống</strong> dựa trên sức chứa của tàu mới. Vui lòng kiểm tra kỹ trước khi lưu.
			</div>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

	<script>
				$(document).ready(function () {
			const giaVeInput = $('#GiaVeDisplay');
			const statusInput = $('#TrangThai');
			const ngayDi = $('#NgayGioKhoiHanh');
			const ngayDen = $('#NgayGioCapBenDuKien');
			const maTuyen = $('#MaTuyen');
			const maTau = $('#MaTau');

			// --- 1. ĐỊNH DẠNG TIỀN (Chém sạch thập phân và số 0 đầu) ---
			function formatCurrency(n) {
				if (!n) return "";
				let value = n.toString().split('.')[0]; // Lấy phần nguyên
				value = value.replace(/\D/g, "");      // Xóa ký tự lạ
				value = value.replace(/^0+/, "");      // Xóa số 0 ở đầu
				return value.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
			}

			giaVeInput.on('input', function () {
				$(this).val(formatCurrency($(this).val()));
			});

			// Định dạng ngay khi load trang
			if (giaVeInput.val()) {
				giaVeInput.val(formatCurrency(giaVeInput.val()));
			}

			// --- 2. GHI ĐÈ VALIDATION ---
			if ($.validator) {
				$.validator.methods.range = function (value, element, param) {
					var cleanValue = value.toString().replace(/,/g, '');
					return this.optional(element) || (Number(cleanValue) >= param[0] && Number(cleanValue) <= param[1]);
				};
				$.validator.methods.number = function (value, element) {
					return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:,\d{3})+)?(?:\.\d+)?$/.test(value);
				};
			}

			// --- 3. LOGIC KHÓA TRƯỜNG DỮ LIỆU ---
			function updateLogic() {
				const now = new Date();
				const departureTime = new Date(ngayDi.val());
				const arrivalTime = new Date(ngayDen.val());
				const currentStatus = statusInput.val();

				if (currentStatus !== "Đã hủy") {
					if (now < departureTime) statusInput.val("Sắp khởi hành");
					else if (now >= departureTime && (isNaN(arrivalTime) || now < arrivalTime)) statusInput.val("Đang vận hành");
					else if (!isNaN(arrivalTime) && now >= arrivalTime) statusInput.val("Hoàn thành");
				}

				if (now > departureTime || currentStatus === "Đang vận hành" || currentStatus === "Hoàn thành") {
					const fields = [ngayDi, ngayDen, maTuyen, maTau, giaVeInput];
					$.each(fields, function(i, f) {
						f.attr('readonly', true);
						if (f.is('select')) f.attr('disabled', true);
						f.css('background-color', '#e9ecef');
					});
				}
			}

			updateLogic();
			ngayDi.on('change', updateLogic);
			ngayDen.on('change', updateLogic);

			// --- 4. XỬ LÝ SUBMIT (QUAN TRỌNG NHẤT) ---
			$('form').on('submit', function (e) {
				// Lấy giá trị đã sạch dấu phẩy
				let rawValue = giaVeInput.val().replace(/,/g, '');

				// Kiểm tra logic ngày trước khi thay đổi giá trị input
				const dTime = new Date(ngayDi.val());
				const aTime = new Date(ngayDen.val());

				if (!isNaN(aTime) && aTime <= dTime) {
					alert("Lỗi: Giờ cập bến phải sau giờ khởi hành!");
					e.preventDefault();
					return false;
				}

				// Gán giá trị sạch vào input để gửi về Server
				giaVeInput.val(rawValue);

				// Bật lại disabled để dữ liệu không bị null khi về Controller
				$('select:disabled').prop('disabled', false);
			});
		});
	</script>
}


@model IEnumerable<WebAppBookingBoat.Models.Ghe>

@{
    ViewData["Title"] = "Quản lý Sơ đồ Ghế";
}

<style>
    /* GIỮ NGUYÊN FORM CỦA LỊCH TRÌNH */
    #dataTable {
        table-layout: fixed;
        width: 100% !important;
        border-collapse: separate;
        border-spacing: 0;
    }

    .col-id {
        width: 80px;
    }

    .col-code {
        width: 120px;
    }

    .col-boat {
        width: auto;
    }

    .col-type {
        width: 150px;
    }

    .col-status {
        width: 140px;
    }

    .col-action {
        width: 130px;
    }

    .btn-modern {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s ease;
        margin: 0 2px;
        text-decoration: none !important;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-view {
        background-color: #e1f5fe;
        color: #039be5;
    }

    .btn-edit {
        background-color: #fff8e1;
        color: #f57f17;
    }

    .btn-delete {
        background-color: #ffebee;
        color: #c62828;
    }

    .btn-view:hover {
        background-color: #039be5;
        color: #fff;
    }

    .btn-edit:hover {
        background-color: #f57f17;
        color: #fff;
    }

    .btn-delete:hover {
        background-color: #c62828;
        color: #fff;
    }

    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        display: block;
        text-align: center;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-chair text-primary mr-2"></i>Quản lý Ghế
        </h1>
        <a asp-action="Create" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> Thêm ghế mới
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                <i class="fas fa-list mr-1"></i> Danh sách sơ đồ ghế trên tàu
            </h6>
        </div>
        <div class="card-body">
            <div class="row mb-3 border-bottom pb-3">
                <div class="col-md-auto mb-2 mb-md-0">
                    <div class="input-group input-group-sm">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-light border-right-0"><i class="fas fa-ship text-primary"></i></span>
                        </div>
                        <select id="boatFilter" class="form-control form-control-sm border-left-0 font-weight-bold" style="width: 200px;">
                            <option value="">Tất cả các tàu</option>
                            @* Logic đổ danh sách tàu để lọc *@
                        </select>
                    </div>
                </div>
                <div class="col-md-auto">
                    <button id="btnResetFilter" class="btn btn-sm btn-light border shadow-sm">
                        <i class="fas fa-sync-alt mr-1"></i> Làm mới
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                @Html.AntiForgeryToken()
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="bg-gray-100 text-dark small font-weight-bold text-uppercase">
                        <tr>
                            <th class="text-center col-id">ID</th>
                            <th class="col-code">Mã Ghế</th>
                            <th class="col-boat">Thuộc Tàu</th>
                            <th class="col-type">Loại Ghế</th>
                            <th class="text-center col-status">Trạng thái</th>
                            <th class="text-center col-action">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center font-weight-bold text-gray-600 small">#@item.MaGhe</td>
                                <td class="font-weight-bold text-primary">@item.TenGhe</td>
                                <td><div class="text-dark small">@item.Tau?.TenTau</div></td>
                                <td>
                                    <span class="badge badge-light border">@item.LoaiGhe</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Details" asp-route-id="@item.MaGhe" class="btn-modern btn-view"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.MaGhe" class="btn-modern btn-edit"><i class="fas fa-edit"></i></a>
                                        <button type="button" class="btn-modern btn-delete btn-delete-ghe"
                                                data-id="@item.MaGhe" data-info="@item.TenGhe">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#dataTable').DataTable({
                "language": { "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                "pageLength": 10,
                "columnDefs": [{ "orderable": false, "targets": [5] }],
                "dom": "<'row'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            $('#boatFilter').on('change', function() {
                table.column(2).search(this.value).draw();
            });

            $('#btnResetFilter').on('click', function() {
                $('#boatFilter').val('');
                table.search('').columns().search('').draw();
            });

            $(document).on('click', '.btn-delete-ghe', function () {
                const id = $(this).data('id');
                const info = $(this).data('info');

                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: `Xóa ghế: ${info}?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e74a3b',
                    confirmButtonText: 'Xóa ngay'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post('@Url.Action("Delete", "Ghes")', { id: id }, function (res) {
                            if (res.success) location.reload();
                            else Swal.fire('Lỗi!', res.message, 'error');
                        });
                    }
                });
            });
        });
    </script>
}
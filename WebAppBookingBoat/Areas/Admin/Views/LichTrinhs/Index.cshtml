@model IEnumerable<WebAppBookingBoat.ViewModels.LichTrinhViewModel>

@{
    ViewData["Title"] = "Quản lý Lịch trình";
}

    <style>
        /* 1. KHUNG BẢNG & TỈ LỆ CỘT */
        #dataTable {
            table-layout: fixed;
            width: 100% !important;
            border-collapse: separate;
            border-spacing: 0;
        }

        .col-id {
            width: 30px;
        }

        .col-route {
            width: auto;
        }

        .col-boat {
            width: 120px;
        }

        .col-time {
            width: 100px;
        }

        .col-price {
            width: 80px;
        }

        .col-seats {
            width: 80px;
        }

        .col-status {
            width: 100px;
        }

        .col-action {
            width: 130px;
        }

        /* 2. STYLE NỘI DUNG */
        .text-route-main {
            display: block;
            font-weight: 700;
            color: #2c3e50;
            line-height: 1.3;
            font-size: 0.95rem;
        }

        /* 3. NÚT THAO TÁC (SOFT UI GIỐNG MẪU) */
        .btn-modern {
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: all 0.2s ease;
            margin: 0 2px;
            text-decoration: none !important;
        }

            .btn-modern:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            }

        .btn-view {
            background-color: #e1f5fe;
            color: #039be5;
        }

        .btn-edit {
            background-color: #fff8e1;
            color: #f57f17;
        }

        .btn-delete {
            background-color: #ffebee;
            color: #c62828;
        }

        .btn-lock {
            background-color: #f5f5f5;
            color: #9e9e9e;
            cursor: not-allowed;
        }

        .btn-view:hover {
            background-color: #039be5;
            color: #fff;
        }

        .btn-edit:hover {
            background-color: #f57f17;
            color: #fff;
        }

        .btn-delete:hover {
            background-color: #c62828;
            color: #fff;
        }

        /* 4. ĐỊNH DẠNG SEARCH & PAGINATION (ĐỒNG BỘ MẪU) */
        .dataTables_wrapper .dataTables_filter input {
            width: 250px !important;
            border: 2px solid #4e73df;
            border-radius: 20px;
            padding-left: 15px !important;
        }

        .pagination .page-item.active .page-link {
            background-color: #4e73df;
            border-color: #4e73df;
        }

        .badge-status {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
        }
    </style>

    <div class="container-fluid">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
                <i class="fas fa-calendar-alt text-primary mr-2"></i>Quản lý Lịch trình
            </h1>
        </div>

        <div class="mb-3">
            <a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
                <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
                <span class="text font-weight-bold">Thiết lập lịch trình mới</span>
            </a>
        </div>

        <div class="card shadow-sm mb-4 border-0">
            <div class="card-header py-3 bg-white border-bottom">
                <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                    <i class="fas fa-list mr-1"></i> Danh sách lịch trình vận tải
                </h6>
            </div>

            <div class="card-body p-0">
                <div class="px-3 pt-3">
                    <div class="card shadow-sm border-0" style="background-color: #f8f9fc;">
                        <div class="card-body py-2">
                            <div class="d-flex align-items-center flex-wrap">
                                <div class="input-group input-group-sm shadow-sm mr-2" style="width: 250px;">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-info text-white border-0"><i class="fas fa-filter"></i></span>
                                    </div>
                                    <select id="statusFilter" class="form-control border-0 font-weight-bold text-info">
                                        <option value="">Tất cả trạng thái</option>
                                        <option value="Sắp khởi hành">Sắp khởi hành</option>
                                        <option value="Đang vận hành">Đang vận hành</option>
                                        <option value="Hoàn thành">Hoàn thành</option>
                                    </select>
                                </div>
                                <button id="btnResetFilter" class="btn btn-sm btn-outline-secondary border-0 rounded-circle shadow-sm bg-white" title="Làm mới">
                                    <i class="fas fa-sync-alt"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive mt-2">
                    <table class="table table-hover align-middle mb-0" id="dataTable">
                        <thead class="bg-light text-muted small font-weight-bold">
                            <tr>
                                <th class="text-center col-id border-0">ID</th>
                                <th class="col-route border-0">Tuyến đường</th>
                                <th class="col-boat border-0">Tàu vận hành</th>
                                <th class="col-time border-0">Thời gian</th>
                                <th class="text-center col-price border-0">Giá vé</th>
                                <th class="text-center col-seats border-0">Ghế trống</th>
                                <th class="text-center col-status border-0">Trạng thái</th>
                                <th class="text-center col-action border-0">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center font-weight-bold text-gray-500 small">#@item.MaLichTrinh</td>
                                    <td>
                                        <span class="text-route-main">@item.TenTuyen</span>
                                        <small class="text-muted"><i class="fas fa-map-marker-alt mr-1"></i>@item.DiemDi → @item.DiemDen</small>
                                    </td>
                                    <td>
                                        <div class="badge badge-light border text-dark p-2 shadow-sm w-100 text-left">
                                            <i class="fas fa-ship mr-1 text-primary"></i> @item.TenTau
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-success font-weight-bold small"><i class="far fa-clock mr-1"></i>@item.NgayGioKhoiHanh.ToString("dd/MM HH:mm")</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Đến: @item.NgayGioCapBenDuKien.ToString("dd/MM HH:mm")</div>
                                    </td>
                                    <td class="text-center font-weight-bold text-primary">@item.GiaVeCoBan.ToString("N0")đ</td>
                                <td class="text-center">
                                    @{
                                        var phanTramTrong = (item.TongSoGhe > 0) ? (item.SoGheTrong * 100 / item.TongSoGhe) : 0;
                                        var badgeClass = "badge-success";
                                        if (item.SoGheTrong == 0) badgeClass = "badge-danger";
                                        else if (phanTramTrong < 20) badgeClass = "badge-warning text-dark";
                                    }
                                    <span class="badge @badgeClass shadow-sm" style="font-size: 0.85rem;">
                                        <i class="fas fa-chair mr-1"></i> @item.SoGheTrong / @item.TongSoGhe
                                    </span>
                                </td>
                                <td class="text-center">
                                    @{
                                        // Lấy thời gian hiện tại để so sánh
                                        var bayGio = DateTime.Now;

                                        // Giả sử item.NgayGioKhoiHanh là thuộc tính chứa thời gian đi của tàu
                                        // Nếu trong ViewModel của Huy chưa có, Huy nên bổ sung vào nhé.

                                        var sClass = "";
                                        var displayStatus = item.TrangThai;

                                        if (item.TrangThai == "Đã hủy")
                                        {
                                            sClass = "badge-danger";
                                        }
                                        else if (item.NgayGioKhoiHanh > bayGio)
                                        {
                                            sClass = "badge-info";
                                            displayStatus = "Sắp khởi hành";
                                        }
                                        else if (item.NgayGioKhoiHanh <= bayGio && item.TrangThai != "Hoàn thành")
                                        {
                                            // Tới giờ rồi nhưng chưa bấm kết thúc chuyến
                                            sClass = "badge-warning text-dark";
                                            displayStatus = "Đang vận hành";
                                        }
                                        else if (item.TrangThai == "Hoàn thành")
                                        {
                                            sClass = "badge-success";
                                            displayStatus = "Hoàn thành";
                                        }
                                        else
                                        {
                                            sClass = "badge-secondary";
                                        }
                                    }
                                    <span class="badge badge-status shadow-sm @sClass">@displayStatus</span>
                                </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center">
                                            <a asp-action="Details" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-view" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                            @if (item.TrangThai == "Sắp khởi hành")
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-edit" title="Sửa"><i class="fas fa-edit"></i></a>
                                                <button type="button" class="btn-modern btn-delete" onclick="deleteLichTrinhAjax(@item.MaLichTrinh, '@item.TenTuyen')" title="Xóa">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="btn-modern btn-lock" title="Đã khóa"><i class="fas fa-lock"></i></span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

@Html.AntiForgeryToken()

@section Scripts {
	<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
	<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
	<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

	<script>
		var table;
		$(document).ready(function() {

					table = $('#dataTable').DataTable({
			"language": {
				"url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
				"search": "Tìm kiếm:", 
				"searchPlaceholder": "Tên tàu, tuyến đường...",
				"paginate": {
					// Thêm icon vào nút phân trang
					"previous": "<i class='fas fa-angle-left'></i>",
					"next": "<i class='fas fa-angle-right'></i>",
					"first": "<i class='fas fa-angle-double-left'></i>",
					"last": "<i class='fas fa-angle-double-right'></i>"
				}
			},
			"pageLength": 10,
			"order": [[0, "desc"]],
			"dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
					"<'row'<'col-sm-12'tr>>" +
					"<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
		});

			// Kết nối Select lọc trạng thái với DataTable
			$('#statusFilter').on('change', function() {
			var val = $(this).val();
			// Cột Trạng thái của Huy là cột thứ 7 (Index 6)
			// Dùng Regex ^...$ để khớp chính xác cụm từ (tránh lọc "Đang vận hành" ra cả "Hoàn thành")
			table.column(6).search(val ? '^' + val + '$' : '', true, false).draw();
		});

			// Nút Reset
			$('#btnResetFilter').on('click', function() {
				$('#statusFilter').val('');
				table.search('').column(6).search('').draw();
			});
		});

		</script>

		<script>
		// Cập nhật lại hàm xóa cho đúng Controller LichTrinhs
		function deleteLichTrinhAjax(id, route) {
			Swal.fire({
				title: 'Xác nhận xóa?',
				text: `Bạn có chắc muốn xóa lịch trình: "${route}" (Mã: #${id})?`,
				icon: 'warning',
				showCancelButton: true,
				confirmButtonColor: '#e74a3b',
				cancelButtonColor: '#858796',
				confirmButtonText: 'Đồng ý',
				cancelButtonText: 'Hủy'
			}).then((result) => {
				if (result.isConfirmed) {
					$.ajax({
						url: '@Url.Action("Delete", "LichTrinhs")', // Sửa lại đúng tên Controller
						type: 'POST',
						data: {
							id: id,
							__RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
						},
						success: function (response) {
							if (response.success) {
								Swal.fire({
									title: 'Thành công!',
									text: response.message,
									icon: 'success',
									timer: 1500,
									showConfirmButton: false
								}).then(() => {
									location.reload(); // Reload để đồng bộ dữ liệu
								});
							} else {
								Swal.fire('Lỗi!', response.message, 'error');
							}
						},
						error: function () {
							Swal.fire('Thất bại!', 'Có lỗi xảy ra khi kết nối máy chủ.', 'error');
						}
					});
				}
			});
		}
	</script>
}
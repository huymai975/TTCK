@model IEnumerable<WebAppBookingBoat.Models.LichTrinh>

@{
    ViewData["Title"] = "Quản lý Lịch trình Vận hành";
}

<style>
    /* 1. KHUNG BẢNG & TỈ LỆ CỘT (Đồng bộ trang Tàu) */
    #dataTable {
        table-layout: fixed;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .col-id {
        width: 30px;
    }

    .col-route {
        width: auto;
    }

    .col-boat {
        width: 150px;
    }

    .col-time {
        width: 90px;
    }

    .col-price {
        width: 100px;
    }

    .col-seats {
        width: 80px;
    }

    .col-status {
        width: 125px;
    }

    .col-action {
        width: 130px;
    }

    /* 2. STYLE NỘI DUNG */
    .text-route {
        display: block;
        font-weight: 700;
        color: #2c3e50;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.95rem;
    }

    .time-box {
        font-size: 0.85rem;
        line-height: 1.5;
    }

    /* 3. NÚT THAO TÁC (SOFT UI) */
    .btn-modern {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s ease;
        margin: 0 2px;
        text-decoration: none !important;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-view {
        background-color: #e1f5fe;
        color: #039be5;
    }

    .btn-edit {
        background-color: #fff8e1;
        color: #f57f17;
    }

    .btn-delete {
        background-color: #ffebee;
        color: #c62828;
    }

    .btn-lock {
        background-color: #f8f9fa;
        color: #a0a0a0;
        cursor: not-allowed;
    }

    .btn-view:hover {
        background-color: #039be5;
        color: #fff;
    }

    .btn-edit:hover {
        background-color: #f57f17;
        color: #fff;
    }

    .btn-delete:hover {
        background-color: #c62828;
        color: #fff;
    }

    /* 4. BADGE TRẠNG THÁI (Đồng bộ trang Tàu) */
    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        display: inline-block;
        width: 100%;
        text-align: center;
        border: none;
    }

    /* Tùy chỉnh phân trang giống trang Tàu */
    .pagination .page-item.active .page-link {
        background-color: #4e73df;
        border-color: #4e73df;
    }

    .pagination .page-link {
        color: #4e73df;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-calendar-alt text-primary mr-2"></i>Quản lý Lịch trình
        </h1>
    </div>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
            <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
            <span class="text font-weight-bold">Thiết lập lịch trình mới</span>
        </a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header py-3 bg-white border-bottom">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                <i class="fas fa-list mr-1"></i> Danh sách chuyến vận tải
            </h6>
        </div>

        <div class="card-body p-0">
            <div class="px-3 pt-3">
                <div class="card shadow-sm border-0" style="background-color: #f8f9fc;">
                    <div class="card-body py-2">
                        <div class="row align-items-center">
                            <div class="col-md-12 d-flex align-items-center flex-wrap">
                                <div class="input-group input-group-sm shadow-sm mr-3" style="width: 200px;">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-primary text-white border-0"><i class="fas fa-filter"></i></span>
                                    </div>
                                    <select id="statusFilter" class="form-control border-0 font-weight-bold text-primary">
                                        <option value="">Tất cả trạng thái</option>
                                        <option value="Sắp khởi hành">Sắp khởi hành</option>
                                        <option value="Đang vận hành">Đang vận hành</option>
                                        <option value="Hoàn thành">Hoàn thành</option>
                                        <option value="Đã hủy">Đã hủy</option>
                                    </select>
                                </div>

                                <div class="input-group input-group-sm shadow-sm mr-2" style="width: 220px;">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-success text-white border-0"><i class="fas fa-calendar-day"></i></span>
                                    </div>
                                    <input type="date" id="dateFilter" class="form-control border-0 font-weight-bold text-success" placeholder="Chọn ngày khởi hành">
                                </div>

                                <button id="btnResetFilter" class="btn btn-sm btn-outline-secondary border-0 rounded-circle shadow-sm bg-white" title="Làm mới">
                                    <i class="fas fa-sync-alt"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive mt-2">
                <table class="table table-hover align-middle mb-0" id="dataTable">
                    <thead class="bg-light text-muted small font-weight-bold">
                        <tr>
                            <th class="text-center col-id border-0">ID</th>
                            <th class="col-route border-0">Tuyến đường</th>
                            <th class="col-boat border-0">Tàu</th>
                            <th class="col-time border-0">Thời gian</th>
                            <th class="text-center col-price border-0">Giá vé</th>
                            <th class="text-center col-seats border-0">Trống</th>
                            <th class="text-center col-status border-0">Trạng thái</th>
                            <th class="text-center col-action border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center font-weight-bold text-gray-500 small align-middle">#@item.MaLichTrinh</td>
                                <td class="align-middle">
                                    <span class="text-route">@item.TuyenDuong?.TenTuyen</span>
                                    <small class="text-muted text-uppercase" style="font-size: 0.65rem;">
                                        @item.TuyenDuong?.DiemDi → @item.TuyenDuong?.DiemDen
                                    </small>
                                </td>
                                <td class="align-middle"><div class="font-weight-bold text-dark small">@item.Tau?.TenTau</div></td>
                                <td class="time-box align-middle">
                                    <div class="text-success font-weight-bold"><i class="far fa-clock mr-1"></i>@item.NgayGioKhoiHanh.ToString("dd/MM HH:mm")</div>
                                    <div class="text-muted small">→ @item.NgayGioCapBenDuKien.ToString("dd/MM HH:mm")</div>
                                </td>
                                <td class="text-center font-weight-bold text-primary align-middle">@item.GiaVeCoBan.ToString("N0")đ</td>
                                <td class="text-center align-middle">
                                    <span class="badge @(item.SoGheTrong == 0 ? "badge-danger" : "badge-light border") shadow-sm">
                                        @item.SoGheTrong/@(item.Tau?.TongSoGhe ?? 0)
                                    </span>
                                </td>
                                <td class="text-center align-middle">
                                    @{
                                        var sClass = item.TrangThai switch
                                        {
                                            "Sắp khởi hành" => "badge-info",
                                            "Đang vận hành" => "badge-warning text-dark",
                                            "Hoàn thành" => "badge-success",
                                            "Đã hủy" => "badge-danger",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge badge-status shadow-sm @sClass">@item.TrangThai</span>
                                </td>
                                <td class="text-center align-middle">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Details" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-view" title="Chi tiết"><i class="fas fa-eye"></i></a>

                                        @if (item.TrangThai == "Sắp khởi hành")
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-edit" title="Sửa"><i class="fas fa-edit"></i></a>
                                        }
                                        else
                                        {
                                            <span class="btn-modern btn-lock" title="Chuyến đi đã hoặc đang chạy"><i class="fas fa-lock"></i></span>
                                        }

                                        <a asp-action="Delete" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-delete" title="Xóa"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <script>
        $(document).ready(function() {
            var table = $('#dataTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
                    "searchPlaceholder": "Tìm tuyến, tàu, ngày...",
                    "search": "",
                    // 1. Dấu điều khiển phân trang giống index taus
                    "paginate": {
                        "previous": "<i class='fas fa-chevron-left'></i>",
                        "next": "<i class='fas fa-chevron-right'></i>"
                    }
                },
                "pageLength": 10,
                "order": [[3, "desc"]],
                "columnDefs": [
                    { "orderable": false, "targets": [7] },
                    { "className": "align-middle", "targets": "_all" }
                ],
                "dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
                "drawCallback": function() {
                    $('.dataTables_paginate > .pagination').addClass('pagination-sm');
                }
            });

            // Logic lọc trạng thái (Regex chính xác)
            $('#statusFilter').on('change', function() {
                var val = $(this).val();
                table.column(6).search(val ? '^' + val + '$' : '', true, false).draw();
            });

            // Reset lọc
            $('#btnResetFilter').on('click', function() {
                $('#statusFilter').val('');
                table.column(6).search('').draw();
            });
        });
    </script>
}
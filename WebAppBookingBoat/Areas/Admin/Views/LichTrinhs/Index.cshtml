@model IEnumerable<WebAppBookingBoat.Models.LichTrinh>

@{
    ViewData["Title"] = "Quản lý Lịch trình Vận hành";
}

<style>
    /* 1. KHUNG BẢNG CÂN ĐỐI */
    #dataTable {
        table-layout: fixed;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    /* Tỉ lệ cột cho Lịch trình */
    .col-id {
        width: 30px;
    }

    .col-route {
        width: auto;
    }

    .col-boat {
        width: 150px;
    }

    .col-time {
        width: 80px;
    }

    .col-price {
        width: 120px;
    }

    .col-seats {
        width: 100px;
    }

    .col-status {
        width: 130px;
    }

    .col-action {
        width: 140px;
    }

    /* 2. STYLE NỘI DUNG */
    .text-route {
        display: block;
        font-weight: 700;
        color: #2c3e50;
        line-height: 1.2;
    }

    .time-box {
        font-size: 0.8rem;
        line-height: 1.4;
    }

    /* 3. NÚT THAO TÁC (SOFT UI) */
    .btn-modern {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s ease;
        margin: 0 2px;
        text-decoration: none !important;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-view {
        background-color: #e1f5fe;
        color: #039be5;
    }

    .btn-edit {
        background-color: #fff8e1;
        color: #f57f17;
    }

    .btn-delete {
        background-color: #ffebee;
        color: #c62828;
    }

    .btn-view:hover {
        background-color: #039be5;
        color: #fff;
    }

    .btn-edit:hover {
        background-color: #f57f17;
        color: #fff;
    }

    .btn-delete:hover {
        background-color: #c62828;
        color: #fff;
    }

    /* 4. BADGE TRẠNG THÁI */
    .badge-status {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
            <i class="fas fa-calendar-alt text-primary mr-2"></i>Quản lý Lịch trình
        </h1>
    </div>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm border-0">
            <span class="icon text-white-50">
                <i class="fas fa-plus"></i>
            </span>
            <span class="text font-weight-bold">Thiết lập lịch trình mới</span>
        </a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header py-3 bg-white border-bottom">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase small">
                <i class="fas fa-list mr-1"></i> Danh sách chuyến vận tải
            </h6>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="dataTable">
                    <thead class="bg-light text-muted small font-weight-bold">
                        <tr>
                            <th class="text-center col-id">ID</th>
                            <th class="col-route">Tuyến đường</th>
                            <th class="col-boat">Tàu vận hành</th>
                            <th class="col-time">Thời gian</th>
                            <th class="text-center col-price">Giá vé</th>
                            <th class="text-center col-seats">Ghế trống</th>
                            <th class="text-center col-status">Trạng thái</th>
                            <th class="text-center col-action">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center font-weight-bold text-gray-500 small">#@item.MaLichTrinh</td>
                                <td>
                                    <span class="text-route">@item.TuyenDuong.TenTuyen</span>
                                    <small class="text-muted"><i class="fas fa-map-marker-alt mr-1"></i>@item.TuyenDuong.DiemDi → @item.TuyenDuong.DiemDen</small>
                                </td>
                                <td>
                                    <div class="font-weight-bold text-dark small">@item.Tau.TenTau</div>
                                    <div class="progress progress-custom mt-1" style="height: 4px;">
                                        <div class="progress-bar bg-info" style="width: 100%"></div>
                                    </div>
                                </td>
                                <td class="time-box">
                                    <div class="text-success font-weight-bold"><i class="far fa-clock mr-1"></i>@item.NgayGioKhoiHanh.ToString("dd/MM HH:mm")</div>
                                    <div class="text-muted small"><i class="fas fa-long-arrow-alt-right mr-1"></i>@item.NgayGioCapBenDuKien.ToString("dd/MM HH:mm")</div>
                                </td>
                                <td class="text-center">
                                    <span class="font-weight-bold text-primary">@item.GiaVeCoBan.ToString("N0")đ</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(item.SoGheTrong > 0 ? "badge-light text-dark border" : "badge-danger")">
                                        @item.SoGheTrong/@item.Tau.TongSoGhe
                                    </span>
                                </td>
                                <td class="text-center">
                                    @{
                                        var statusClass = item.TrangThai switch
                                        {
                                            "Sắp khởi hành" => "badge-info",
                                            "Đang vận hành" => "badge-warning",
                                            "Hoàn thành" => "badge-success",
                                            "Đã hủy" => "badge-danger",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge badge-status @statusClass shadow-sm">@item.TrangThai</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center">
                                        <a asp-action="Details" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-view" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-edit" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaLichTrinh" class="btn-modern btn-delete" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json",
                    "searchPlaceholder": "Tìm tuyến, tàu, ngày..."
                },
                "pageLength": 10,
                "order": [[3, "desc"]], // Sắp xếp theo thời gian mới nhất
                "columnDefs": [
                    { "orderable": false, "targets": [7] }
                ],
                "dom": "<'row px-3 py-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row px-3 py-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });
        });
    </script>
}
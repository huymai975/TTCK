@model WebAppBookingBoat.ViewModels.LichTrinhViewModel

@{
	ViewData["Title"] = "Thiết lập Lịch trình mới";
}

<div class="container-fluid">
	<div class="d-sm-flex align-items-center justify-content-between mb-4">
		<h1 class="h3 mb-0 text-gray-800 font-weight-bold">
			<i class="fas fa-calendar-plus text-primary mr-2"></i>Thiết lập Lịch trình mới
		</h1>
	</div>

	<div class="row justify-content-center">
		<div class="col-xl-10 col-lg-12">
			<div class="card shadow-sm mb-4 border-0">
				<div class="card-header py-3 bg-white border-bottom">
					<h6 class="m-0 font-weight-bold text-primary text-uppercase small">
						<i class="fas fa-info-circle mr-1"></i> Thông tin vận hành lịch trình
					</h6>
				</div>

				<div class="card-body px-lg-5 py-4">
					<form asp-action="Create" method="post" id="createScheduleForm">
						<div asp-validation-summary="ModelOnly" class="alert alert-danger small shadow-sm" role="alert"></div>

						<div class="row">
							<div class="col-md-6 border-right">
								<h6 class="font-weight-bold text-dark mb-3"><i class="fas fa-anchor mr-2 text-primary"></i>Phân bổ phương tiện</h6>

								<div class="form-group mb-4">
									<label asp-for="MaTuyen" class="small font-weight-bold text-muted text-uppercase">Tuyến đường vận hành</label>
									<select asp-for="MaTuyen" class="form-control form-control-user border-left-primary shadow-sm" asp-items="Model.DanhSachTuyen">
										<option value="">-- Chọn lộ trình xuất phát --</option>
									</select>
									<span asp-validation-for="MaTuyen" class="text-danger small mt-1"></span>
								</div>

								<div class="form-group mb-4">
									<label asp-for="MaTau" class="small font-weight-bold text-muted text-uppercase">Phương tiện thực hiện</label>
									<select asp-for="MaTau" class="form-control form-control-user border-left-info shadow-sm" asp-items="Model.DanhSachTau">
										<option value="">-- Chọn tàu trong đội ngũ --</option>
									</select>
									<span asp-validation-for="MaTau" class="text-danger small mt-1"></span>
								</div>

								<div class="form-group mb-4">
									<label asp-for="GiaVeCoBan" class="small font-weight-bold text-muted text-uppercase">Giá vé niêm yết (VNĐ)</label>
									<div class="input-group">
										<div class="input-group-prepend">
											<span class="input-group-text bg-light border-right-0"><i class="fas fa-money-bill-wave text-success"></i></span>
										</div>
										@* Dùng duy nhất 1 input text. data-val="false" để tắt check mặc định, mình sẽ check bằng JS *@
										<input asp-for="GiaVeCoBan" type="text" id="GiaVeDisplay"
											   class="form-control shadow-sm border-left-0"
											   placeholder="Ví dụ: 250,000" inputmode="numeric" />
									</div>
									<span asp-validation-for="GiaVeCoBan" class="text-danger small mt-1"></span>
								</div>
							</div>

							<div class="col-md-6 pl-md-4">
								<h6 class="font-weight-bold text-dark mb-3"><i class="fas fa-clock mr-2 text-primary"></i>Thời gian dự kiến</h6>
								<div class="form-group mb-4">
									<label asp-for="NgayGioKhoiHanh" class="small font-weight-bold text-muted text-uppercase">Giờ khởi hành</label>
									<input asp-for="NgayGioKhoiHanh" type="datetime-local" class="form-control shadow-sm border-left-warning" />
									<span asp-validation-for="NgayGioKhoiHanh" class="text-danger small mt-1"></span>
								</div>

								<div class="form-group mb-4">
									<label asp-for="NgayGioCapBenDuKien" class="small font-weight-bold text-muted text-uppercase">Giờ cập bến dự kiến</label>
									<input asp-for="NgayGioCapBenDuKien" type="datetime-local" class="form-control shadow-sm border-left-danger" />
									<span asp-validation-for="NgayGioCapBenDuKien" class="text-danger small mt-1"></span>
								</div>

								<div class="form-group mb-4">
									<label asp-for="TrangThai" class="small font-weight-bold text-muted text-uppercase">Trạng thái khởi tạo</label>
									<select asp-for="TrangThai" class="form-control shadow-sm">
										<option value="Sắp khởi hành">Sắp khởi hành</option>
										<option value="Đang vận hành">Đang vận hành</option>
										<option value="Hoàn thành">Hoàn thành</option>
										<option value="Đã hủy">Đã hủy</option>
									</select>
									<span asp-validation-for="TrangThai" class="text-danger small mt-1"></span>
								</div>
							</div>
						</div>

						<hr class="my-4">

						<div class="d-flex justify-content-between align-items-center mt-4">
							<a asp-action="Index" class="btn btn-secondary btn-icon-split shadow-sm">
								<span class="icon text-white-50"><i class="fas fa-arrow-left"></i></span>
								<span class="text font-weight-bold">Quay lại danh sách</span>
							</a>
							<div>
								<button type="reset" class="btn btn-light btn-icon-split mr-2">
									<span class="text">Nhập lại</span>
								</button>
								<button type="submit" class="btn btn-primary btn-icon-split shadow-sm">
									<span class="icon text-white-50"><i class="fas fa-save"></i></span>
									<span class="text font-weight-bold">Khởi tạo lịch trình</span>
								</button>
							</div>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

	<style>
		.form-control-user {
			border-radius: 8px;
			height: calc(1.5em + .75rem + 10px);
		}

		.border-left-primary {
			border-left: 4px solid #4e73df !important;
		}

		.border-left-info {
			border-left: 4px solid #36b9cc !important;
		}

		.border-left-warning {
			border-left: 4px solid #f6c23e !important;
		}

		.border-left-danger {
			border-left: 4px solid #e74a3b !important;
		}

		.input-group-text {
			border-radius: 8px 0 0 8px;
		}
	</style>

	<script>
		$(document).ready(function () {
			const giaVeInput = $('#GiaVeDisplay');
			const ngayDiInput = $('#NgayGioKhoiHanh');
			const ngayDenInput = $('#NgayGioCapBenDuKien');
			const trangThaiSelect = $('#TrangThai');

			// --- 1. ĐỊNH DẠNG TIỀN (VNĐ) ---
					function formatCurrency(n) {
			// Xóa tất cả ký tự không phải số
			let value = n.replace(/\D/g, "");

			// CHỖ NÀY: Xóa số 0 ở đầu nếu có (trừ khi chỉ có duy nhất một số 0)
			value = value.replace(/^0+/, "");

			// Định dạng dấu phẩy hàng nghìn
			return value.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
		}

					giaVeInput.on('input', function () {
			let rawValue = $(this).val();
			let formatted = formatCurrency(rawValue);

			$(this).val(formatted);
		});

			// --- 2. GHI ĐÈ VALIDATION (Quan trọng để không bị lỗi 1,000đ) ---
			if ($.validator) {
				$.validator.methods.range = function (value, element, param) {
					// Xóa dấu phẩy trước khi validate giá trị range
					var cleanValue = value.replace(/,/g, '');
					return this.optional(element) || (cleanValue >= param[0] && cleanValue <= param[1]);
				};

				$.validator.methods.number = function (value, element) {
					// Cho phép dấu phẩy khi check có phải là số hay không
					return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:,\d{3})+)?(?:\.\d+)?$/.test(value);
				};
			}

			// --- 3. TỰ ĐỘNG CẬP NHẬT TRẠNG THÁI ---
			function updateStatusByTime() {
				const now = new Date();
				const ngayDi = new Date(ngayDiInput.val());
				const ngayDen = new Date(ngayDenInput.val());

				if (!ngayDiInput.val()) {
					trangThaiSelect.val("Sắp khởi hành");
					return;
				}

				if (now < ngayDi) {
					trangThaiSelect.val("Sắp khởi hành");
				} else if (now >= ngayDi && (!ngayDenInput.val() || now < ngayDen)) {
					trangThaiSelect.val("Đang vận hành");
				} else if (ngayDenInput.val() && now >= ngayDen) {
					trangThaiSelect.val("Hoàn thành");
				}
			}

			ngayDiInput.on('change', updateStatusByTime);
			ngayDenInput.on('change', updateStatusByTime);

			// --- 4. XỬ LÝ KHI SUBMIT ---
			$('#createScheduleForm').on('submit', function (e) {
				// Làm sạch giá vé để gửi về Server
				let displayVal = giaVeInput.val();
				let rawValue = displayVal.replace(/,/g, '');

				// Gán giá trị không dấu phẩy để Backend nhận đúng kiểu số
				giaVeInput.val(rawValue);

				const ngayDi = new Date(ngayDiInput.val());
				const ngayDen = new Date(ngayDenInput.val());

				if (!isNaN(ngayDen) && ngayDen <= ngayDi) {
					alert("Lỗi: Giờ cập bến dự kiến phải sau giờ khởi hành!");
					giaVeInput.val(formatCurrency(rawValue)); // Trả lại định dạng cho đẹp nếu lỗi
					e.preventDefault();
					return false;
				}
			});
		});
	</script>
}
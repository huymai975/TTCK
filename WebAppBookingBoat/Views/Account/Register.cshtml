@model WebAppBookingBoat.Models.ViewModels.RegisterVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Đăng ký - Boat Booking</title>

    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">

    <link href="~/css/sb-admin-2.min.css" rel="stylesheet">
</head>

<body class="bg-gradient-primary">

    <div class="container">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <div class="row">
                    <div class="col-lg-5 d-none d-lg-block bg-register-image"></div>
                    <div class="col-lg-7">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4">Tạo tài khoản mới!</h1>
                            </div>

                            <form asp-action="Register" asp-controller="Account" method="post" class="user">
                                @* Hiển thị các lỗi tổng quát từ Server (ví dụ: Trùng tên đăng nhập) *@
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                                <div class="form-group">
                                    <input asp-for="TenDangNhap" class="form-control form-control-user" placeholder="Tên đăng nhập">
                                    <span asp-validation-for="TenDangNhap" class="text-danger small ml-3"></span>
                                </div>

                                <div class="form-group">
                                    <input asp-for="Email" class="form-control form-control-user" placeholder="Địa chỉ Email">
                                    <span asp-validation-for="Email" class="text-danger small ml-3"></span>
                                </div>

                                <div class="form-group row">
                                    <div class="col-sm-6 mb-3 mb-sm-0">
                                        <input asp-for="MatKhau" class="form-control form-control-user" placeholder="Mật khẩu">
                                        <span asp-validation-for="MatKhau" class="text-danger small ml-3"></span>
                                    </div>
                                    <div class="col-sm-6">
                                        <input asp-for="NhapLaiMatKhau" class="form-control form-control-user" placeholder="Nhập lại mật khẩu">
                                        <span asp-validation-for="NhapLaiMatKhau" class="text-danger small ml-3"></span>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary btn-user btn-block">
                                    Đăng ký tài khoản
                                </button>
                                <hr>
                                <a href="#" class="btn btn-google btn-user btn-block">
                                    <i class="fab fa-google fa-fw"></i> Register with Google
                                </a>
                                <a href="#" class="btn btn-facebook btn-user btn-block">
                                    <i class="fab fa-facebook-f fa-fw"></i> Register with Facebook
                                </a>
                            </form>

                            <hr>
                            <div class="text-center">
                                <a class="small" href="#">Quên mật khẩu?</a>
                            </div>
                            <div class="text-center">
                                <a class="small" asp-controller="Account" asp-action="Login">Đã có tài khoản? Đăng nhập!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script src="~/vendor/jquery-easing/jquery.easing.min.js"></script>

    <script src="~/js/sb-admin-2.min.js"></script>

    @* QUAN TRỌNG: Thêm các thư viện Validation để kiểm tra lỗi ngay tại trình duyệt *@
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>